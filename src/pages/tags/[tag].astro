---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  const uniqueTags = [...new Set(allPosts.map((post) => (post.data.tags?.[0] || 'other').toLowerCase()))];

  return uniqueTags.map((tag) => {
    const posts = allPosts
      .filter((post) => (post.data.tags?.[0] || 'other').toLowerCase() === tag)
      .sort((a, b) => {
        const ad = a.data.event_date || a.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
        const bd = b.data.event_date || b.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
        return bd.localeCompare(ad);
      });

    return {
      params: { tag },
      props: { posts, currentTag: tag.toUpperCase(), allTags: uniqueTags.sort() },
    };
  });
}

const { posts, currentTag, allTags } = Astro.props;
---

<Layout title={`${currentTag} Event Research`} description={`${currentTag} CPI/NFP/FOMC event-driven probability pages.`}>
  <section class="py-12 hero-panel">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-extrabold text-white">{currentTag} Event Research</h1>
      <p class="text-blue-100 mt-3 text-lg">{posts.length} pages with historical event probabilities.</p>
    </div>
  </section>

  <section class="py-6 border-b" style="border-color:var(--border);background:var(--surface);">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-wrap gap-2">
        <a href="/blog" class="badge-chip" data-track-event="filter_apply" data-filter="all">All</a>
        {allTags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class={`badge-chip ${tag.toUpperCase() === currentTag ? 'font-extrabold' : ''}`}
            data-track-event="filter_apply"
            data-filter={tag}
          >
            {tag.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
      {posts.map((post) => {
        const signal = post.data.signal || 'Neutral';
        const signalClass = signal === 'Bullish' ? 'metric-up' : signal === 'Bearish' ? 'metric-down' : 'metric-muted';
        return (
          <a href={`/blog/${post.slug}`} class="surface-card p-5 flex flex-col gap-3 hover:translate-y-[-2px] transition-transform">
            <div class="flex items-center gap-2">
              <span class="badge-chip">{post.data.event_label || post.data.event_type}</span>
              <span class={`text-xs font-bold ${signalClass}`}>{signal}</span>
            </div>
            <h2 class="text-lg font-bold">{post.data.title}</h2>
            <p class="text-sm" style="color:var(--muted);">{post.data.description}</p>
            <div class="text-xs mt-auto" style="color:var(--muted);">
              Event date: {post.data.event_date || '--'} · As-of: {post.data.asof_date || '--'}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
