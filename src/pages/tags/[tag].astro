---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  const uniqueTags = [...new Set(
    allPosts.map((post) => post.data.tags?.[0]?.toLowerCase() || 'other')
  )];
  
  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter(
      (post) => (post.data.tags?.[0]?.toLowerCase() || 'other') === tag
    );
    
    return {
      params: { tag: tag.toLowerCase() },
      props: { 
        posts: filteredPosts, 
        currentTag: tag.toUpperCase(),
        allTags: uniqueTags 
      },
    };
  });
}

const { posts, currentTag, allTags } = Astro.props;
const { tag } = Astro.params;
---

<Layout title={currentTag + " Analysis | QuantMacro"}>
  <main class="max-w-7xl mx-auto px-4 py-12">
    <header class="mb-12 text-center">
      <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
        {currentTag} Quantitative Data
      </h1>
      <p class="text-xl text-gray-500">
        Showing {posts.length} backtested events for {currentTag}
      </p>
    </header>
    
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <a href="/blog" class="px-5 py-2.5 rounded-full text-sm font-semibold bg-gray-100 text-gray-600 hover:bg-gray-200">
        All Assets
      </a>
      {allTags.sort().map((t) => (
        <a href={'/tags/' + t.toLowerCase()} 
           class={'px-5 py-2.5 rounded-full text-sm font-semibold transition ' + 
           (currentTag.toLowerCase() === t.toLowerCase() ? 'bg-blue-600 text-white shadow-md' : 'bg-white text-gray-700 border border-gray-200 hover:bg-gray-50')}>
          {t.toUpperCase()}
        </a>
      ))}
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => {
        const displayTitle = post.data.title.replace(/Historical Correlation of |Price Impact after |Performance after /gi, '');
        return (
          <a href={'/blog/' + post.slug} class="block p-6 bg-white border border-gray-200 rounded-xl shadow-sm hover:border-blue-500 hover:shadow-md transition">
            <div class="flex items-center justify-between mb-3">
              <span class="px-2.5 py-0.5 bg-blue-50 text-blue-700 text-xs font-bold rounded uppercase">
                {post.data.tags?.[0]}
              </span>
            </div>
            <h2 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 line-clamp-2">
              {displayTitle}
            </h2>
            <p class="text-sm text-gray-500 mt-2">{post.data.pubDate}</p>
          </a>
        );
      })}
    </div>
    
    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 text-lg">No articles found for this tag.</p>
      </div>
    )}
  </main>
</Layout>
