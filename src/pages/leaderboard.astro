---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const rows = posts
  .map((post) => {
    const p = post.data.probabilities || {};
    const riseT7 = Number(p?.t7?.up ?? 0);
    const medianT7 = Number(p?.t7?.median ?? 0);
    const riseT1 = Number(p?.t1?.up ?? 0);
    const signalScore = 0.5 * (riseT7 - 50) + 0.3 * (riseT1 - 50) + 0.2 * (Math.sign(medianT7) * 10);

    return {
      slug: post.slug,
      asset: post.data.tags?.[0]?.toUpperCase() || 'UNKNOWN',
      event: post.data.event_label || post.data.event_type,
      direction: (post.data.event_direction || '--').toUpperCase(),
      title: post.data.title,
      signal: post.data.signal || 'Neutral',
      signalScore: Number(signalScore.toFixed(2)),
      riseT1,
      riseT7,
      medianT7,
      sample: Number(p?.sample_size ?? 0),
      asof: post.data.asof_date || '--',
    };
  })
  .sort((a, b) => b.signalScore - a.signalScore);

const bestRows = rows.slice(0, 30);
---

<Layout title="Playbook Leaderboard" description="Ranked CPI/NFP/FOMC event playbooks by signal score and historical probabilities.">
  <section class="py-12 hero-panel">
    <div class="max-w-7xl mx-auto px-4">
      <h1 class="text-4xl font-extrabold text-white">Event Playbook Leaderboard</h1>
      <p class="text-blue-100 text-lg mt-3">Ranked by probability-derived signal score (T+1/T+7 weighted).</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 py-10">
    <div class="surface-card overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[980px] text-sm">
          <thead style="background:var(--surface-alt);color:var(--muted);">
            <tr>
              <th class="text-left px-4 py-3 font-bold">#</th>
              <th class="text-left px-4 py-3 font-bold">Asset</th>
              <th class="text-left px-4 py-3 font-bold">Event</th>
              <th class="text-left px-4 py-3 font-bold">Outcome</th>
              <th class="text-left px-4 py-3 font-bold">Signal</th>
              <th class="text-left px-4 py-3 font-bold">Signal Score</th>
              <th class="text-left px-4 py-3 font-bold">T+1 P(up)</th>
              <th class="text-left px-4 py-3 font-bold">T+7 P(up)</th>
              <th class="text-left px-4 py-3 font-bold">T+7 Median</th>
              <th class="text-left px-4 py-3 font-bold">Sample</th>
              <th class="text-left px-4 py-3 font-bold">As-of</th>
              <th class="text-left px-4 py-3 font-bold">Action</th>
            </tr>
          </thead>
          <tbody>
            {bestRows.map((row, idx) => {
              const signalClass = row.signal === 'Bullish' ? 'metric-up' : row.signal === 'Bearish' ? 'metric-down' : 'metric-muted';
              return (
                <tr class="border-t" style="border-color:var(--border);">
                  <td class="px-4 py-3 font-bold">{idx + 1}</td>
                  <td class="px-4 py-3 font-semibold">{row.asset}</td>
                  <td class="px-4 py-3">{row.event}</td>
                  <td class="px-4 py-3">{row.direction}</td>
                  <td class={`px-4 py-3 font-bold ${signalClass}`}>{row.signal}</td>
                  <td class="px-4 py-3">{row.signalScore}</td>
                  <td class="px-4 py-3">{row.riseT1}%</td>
                  <td class="px-4 py-3">{row.riseT7}%</td>
                  <td class={`px-4 py-3 font-semibold ${row.medianT7 >= 0 ? 'metric-up' : 'metric-down'}`}>{row.medianT7}%</td>
                  <td class="px-4 py-3">{row.sample}</td>
                  <td class="px-4 py-3">{row.asof}</td>
                  <td class="px-4 py-3">
                    <a href={`/blog/${row.slug}`} class="btn-ghost text-xs" data-track-event="playbook_open" data-asset={row.asset} data-event={row.event}>
                      Open
                    </a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>
</Layout>
