---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Get all blog posts
const posts = await getCollection('blog');

// Extract metrics from all posts and sort
const leaderboardData = posts
  .filter(post => post.data.metrics)
  .map(post => ({
    title: post.data.title.replace(/Historical Correlation of |Price Impact after |Performance after |Historical /gi, ''),
    asset: post.data.tags?.[0] || 'Unknown',
    slug: post.slug,
    sharpe: Number(post.data.metrics?.sharpe_t7) || 0,
    mdd: post.data.metrics?.mdd_t7 || 0,
    volatility: post.data.metrics?.volatility || 0,
  }))
  .sort((a, b) => Math.abs(b.sharpe) - Math.abs(a.sharpe)); // Sort by absolute Sharpe

// Group by asset
const assetGroups = {};
leaderboardData.forEach(item => {
  if (!assetGroups[item.asset]) {
    assetGroups[item.asset] = [];
  }
  assetGroups[item.asset].push(item);
});

// Calculate asset averages
const assetStats = Object.entries(assetGroups).map(([asset, items]) => {
  const avgSharpe = items.reduce((sum, i) => sum + i.sharpe, 0) / items.length;
  const avgMdd = items.reduce((sum, i) => sum + i.mdd, 0) / items.length;
  const avgVol = items.reduce((sum, i) => sum + i.volatility, 0) / items.length;
  return {
    asset,
    count: items.length,
    avgSharpe: Math.round(avgSharpe * 100) / 100,
    avgMdd: Math.round(avgMdd * 100) / 100,
    avgVol: Math.round(avgVol * 100) / 100,
  };
}).sort((a, b) => Math.abs(b.avgSharpe) - Math.abs(a.avgSharpe));
---

<Layout title="Alpha Screener | QuantMacro" description="Top quantitative trading strategies ranked by risk-adjusted returns">
  <section class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="text-yellow-400">α</span> Alpha Screener
      </h1>
      <p class="text-xl text-indigo-100">
        Top quantitative strategies ranked by Sharpe Ratio
      </p>
    </div>
  </section>

  <!-- Asset Summary Table -->
  <section class="max-w-6xl mx-auto px-4 py-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Asset Performance Summary</h2>
    
    <div class="overflow-x-auto">
      <table class="w-full bg-white rounded-xl shadow-sm border border-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Asset</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Strategies</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Avg Sharpe</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Avg MDD</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Avg Volatility</th>
            <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {assetStats.map((stat, idx) => (
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center">
                  <span class={`text-lg font-bold mr-2 ${
                    stat.asset === 'BTC' ? 'text-orange-500' :
                    stat.asset === 'ETH' ? 'text-blue-500' :
                    stat.asset === 'GOLD' ? 'text-yellow-600' :
                    stat.asset === 'SPY' ? 'text-green-600' :
                    'text-gray-700'
                  }`}>{stat.asset}</span>
                  {idx < 3 && <span class="text-xs bg-yellow-400 text-yellow-900 px-2 py-0.5 rounded-full font-bold">TOP {idx + 1}</span>}
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-gray-600">{stat.count}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class={`font-bold ${stat.avgSharpe > 0 ? 'text-green-600' : 'text-red-600'}`}>
                  {stat.avgSharpe > 0 ? '↑' : '↓'} {Math.abs(stat.avgSharpe)}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-red-600 font-medium">{stat.avgMdd}%</td>
              <td class="px-6 py-4 whitespace-nowrap text-gray-600">{stat.avgVol && stat.avgVol !== 0 ? stat.avgVol + '%' : '-'}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <a href={`/tags/${stat.asset.toLowerCase()}`} class="text-indigo-600 hover:text-indigo-800 font-medium text-sm">
                  View All →
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Top Strategies List -->
  <section class="max-w-6xl mx-auto px-4 py-8 pb-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">Top Strategies</h2>
    
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {leaderboardData.slice(0, 12).map((item, idx) => (
        <a href={`/blog/${item.slug}`} class="block bg-white rounded-xl shadow-sm hover:shadow-lg transition border border-gray-200 overflow-hidden group">
          <div class="p-5">
            <div class="flex items-center justify-between mb-3">
              <span class={`text-xs font-bold px-2 py-1 rounded ${
                item.asset === 'BTC' ? 'bg-orange-100 text-orange-700' :
                item.asset === 'ETH' ? 'bg-blue-100 text-blue-700' :
                item.asset === 'GOLD' ? 'bg-yellow-100 text-yellow-700' :
                'bg-gray-100 text-gray-700'
              }`}>{item.asset}</span>
              <span class="text-xs text-gray-500">#{idx + 1}</span>
            </div>
            <h3 class="text-sm font-semibold text-gray-900 line-clamp-2 group-hover:text-indigo-600 transition">
              {item.title}
            </h3>
            <div class="mt-3 flex items-center justify-between text-xs">
              <span class={`font-bold ${item.sharpe > 0 ? 'text-green-600' : 'text-red-600'}`}>
                Sharpe: {item.sharpe}
              </span>
              <span class="text-gray-500">MDD: {item.mdd}%</span>
            </div>
          </div>
        </a>
      ))}
    </div>
    
    <div class="text-center mt-8">
      <a href="/blog" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-lg transition-all">
        View All {leaderboardData.length} Strategies →
      </a>
    </div>
  </section>
</Layout>
