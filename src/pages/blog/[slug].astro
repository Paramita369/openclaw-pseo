---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TradingChart from '../../components/TradingChart.astro';
import DynamicCta from '../../components/DynamicCta.astro';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');
  return allEntries.map(entry => {
    // 找出具備相同標籤 (資產) 且排除當前文章的其他文章
    const relatedPosts = allEntries
      .filter(p => p.slug !== entry.slug && p.data.tags?.[0]?.toLowerCase() === entry.data.tags?.[0]?.toLowerCase())
      .slice(0, 3);
    
    return {
      params: { slug: entry.slug },
      props: { entry, relatedPosts },
    };
  });
}

const { entry, relatedPosts } = Astro.props;
const { Content } = await entry.render();

// 標題過濾邏輯
const displayTitle = entry.data.title.replace(/Historical Correlation of |Price Impact after |Performance after /gi, '');
---

<Layout title={displayTitle} frontmatter={entry.data}>
  <main class="max-w-4xl mx-auto px-4 py-10">
    <nav class="mb-8">
      <a href="/" class="text-sm font-medium text-blue-600 hover:text-blue-800 font-mono">← Return to Matrix</a>
    </nav>
    
    <article class="prose prose-slate prose-blue max-w-none bg-white p-8 md:p-12 rounded-3xl border border-gray-100 shadow-sm mb-12">
      <header class="mb-8 border-b border-gray-100 pb-8">
        <h1 class="text-3xl md:text-4xl font-black text-slate-900 mb-4">{displayTitle}</h1>
        <div class="flex gap-2 mb-6">
          {entry.data.tags?.map(tag => (
            <span class="px-2 py-1 bg-slate-100 text-slate-600 text-xs font-bold rounded uppercase tracking-widest">{tag}</span>
          ))}
        </div>
        
        {/* Risk Metrics Display */}
        {entry.data.metrics && (
          <div class="bg-slate-50 rounded-xl p-5 border border-slate-200">
            <h3 class="text-sm font-bold text-slate-500 uppercase tracking-wider mb-4">Risk Profile (T+7)</h3>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
              {entry.data.metrics.sharpe_t7 !== undefined && (
                <div class="bg-white p-4 rounded-lg border border-slate-200">
                  <div class="text-xs text-slate-500 mb-1">Sharpe Ratio</div>
                  <div class="text-xl font-black text-slate-800">{entry.data.metrics.sharpe_t7}</div>
                </div>
              )}
              {entry.data.metrics.mdd_t7 !== undefined && (
                <div class="bg-white p-4 rounded-lg border border-slate-200">
                  <div class="text-xs text-slate-500 mb-1">Max Drawdown</div>
                  <div class="text-xl font-black text-rose-600">{entry.data.metrics.mdd_t7}%</div>
                </div>
              )}
              {entry.data.metrics.volatility !== undefined && entry.data.metrics.volatility !== 'nan' && Number(entry.data.metrics.volatility) !== 0 && (
                <div class="bg-white p-4 rounded-lg border border-slate-200">
                  <div class="text-xs text-slate-500 mb-1">Volatility</div>
                  <div class="text-xl font-black text-slate-800">{entry.data.metrics.volatility}%</div>
                </div>
              )}
            </div>
          </div>
        )}
      </header>
      
      {/* TradingView Chart */}
      {entry.data.chartData && entry.data.chartData.length > 0 && (
        <TradingChart 
          data={entry.data.chartData} 
          asset={entry.data.tags?.[0]} 
        />
      )}
      
      <Content />
    </article>

    {relatedPosts.length > 0 && (
      <section class="border-t border-gray-200 pt-10">
        <h3 class="text-xl font-bold text-gray-900 mb-6">Related Quantitative Analysis</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(post => {
            const relatedTitle = post.data.title.replace(/Historical Correlation of |Price Impact after |Performance after /gi, '');
            return (
              <a href={`/blog/${post.slug}`} class="block p-5 bg-white border border-gray-200 rounded-xl shadow-sm hover:border-blue-400 hover:shadow-md transition-all">
                <div class="text-xs font-bold text-blue-600 uppercase mb-2">{post.data.tags?.[0]}</div>
                <h4 class="text-sm font-semibold text-gray-800 line-clamp-3">{relatedTitle}</h4>
              </a>
            );
          })}
        </div>
      </section>
    )}
  </main>
</Layout>
