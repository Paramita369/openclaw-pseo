---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import TradingChart from '../../components/TradingChart.astro';
import DynamicCta from '../../components/DynamicCta.astro';

export async function getStaticPaths() {
  const allEntries = await getCollection('blog');

  const metricNumber = (post, key) => Number(post.data.metrics?.[key] ?? 0);
  const similarityScore = (base, candidate) => {
    const mddDiff = Math.abs(metricNumber(base, 'mdd_t7') - metricNumber(candidate, 'mdd_t7'));
    const volDiff = Math.abs(metricNumber(base, 'volatility') - metricNumber(candidate, 'volatility'));
    const impactDiff = Math.abs(metricNumber(base, 'impact_t7_pct') - metricNumber(candidate, 'impact_t7_pct'));
    return mddDiff * 0.6 + volDiff * 0.2 + impactDiff * 0.2;
  };

  return allEntries.map((entry) => {
    const baseAsset = entry.data.tags?.[0]?.toLowerCase();
    const baseEvent = String(entry.data.event_type || '').toUpperCase();

    const relatedPosts = allEntries
      .filter((p) => p.slug !== entry.slug && p.data.tags?.[0]?.toLowerCase() === entry.data.tags?.[0]?.toLowerCase())
      .slice(0, 3);

    const similarPosts = allEntries
      .filter(
        (p) =>
          p.slug !== entry.slug &&
          p.data.tags?.[0]?.toLowerCase() === baseAsset &&
          String(p.data.event_type || '').toUpperCase() === baseEvent
      )
      .map((post) => ({ post, score: similarityScore(entry, post) }))
      .sort((a, b) => a.score - b.score)
      .slice(0, 5)
      .map((item) => item.post);

    return {
      params: { slug: entry.slug },
      props: { entry, relatedPosts, similarPosts },
    };
  });
}

const { entry, relatedPosts, similarPosts = [] } = Astro.props;
const { Content } = await entry.render();

const displayTitle = entry.data.title;
const p = entry.data.probabilities || null;
const t1 = p?.t1 || {};
const t7 = p?.t7 || {};
const conditional = p?.conditional || {};
const c1 = conditional?.t1 || {};
const c7 = conditional?.t7 || {};
const signal = entry.data.signal || 'Neutral';
const signalText =
  signal === 'Bullish'
    ? 'Historical odds and median return currently lean positive after this event type.'
    : signal === 'Bearish'
      ? 'Historical odds and median return currently lean negative after this event type.'
      : 'Historical odds are mixed, so position sizing and risk controls matter most.';

const sampleSize = p?.sample_size ?? t1.sample ?? t7.sample ?? entry.data.sample_size ?? '--';
const eventDate = entry.data.event_date || entry.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '--';
const eventLabel = entry.data.event_label || entry.data.event_type || '--';
const asofDate = entry.data.asof_date || '--';
const eventDirection = String(entry.data.event_direction || conditional?.direction || '--').toUpperCase();
const eventActual = entry.data.event_actual;
const eventPrevious = entry.data.event_previous;
const eventDelta = entry.data.event_delta;
const conditionalSample = conditional?.sample_size ?? '--';
const freshnessDays = entry.data.freshness_days;
---

<Layout title={displayTitle} description={entry.data.description} frontmatter={entry.data}>
  <section class="py-10">
    <main class="max-w-5xl mx-auto px-4">
      <nav class="mb-6 text-sm" style="color:var(--muted);">
        <a href="/blog" class="hover:underline">Research</a>
        <span class="mx-2">/</span>
        <a href={`/tags/${(entry.data.tags?.[0] || '').toLowerCase()}`} class="hover:underline">{entry.data.tags?.[0]?.toUpperCase()}</a>
      </nav>

      <article class="surface-card p-6 md:p-8">
        <header>
          <div class="flex flex-wrap items-center gap-2 mb-3">
            <span class="badge-chip">{entry.data.tags?.[0]?.toUpperCase()}</span>
            <span class="badge-chip">{eventLabel}</span>
            <span class={`text-xs font-bold ${signal === 'Bullish' ? 'metric-up' : signal === 'Bearish' ? 'metric-down' : 'metric-muted'}`}>
              {signal}
            </span>
          </div>

          <h1 class="text-3xl md:text-4xl font-extrabold leading-tight">{displayTitle}</h1>
          <p class="mt-3 text-sm" style="color:var(--muted);">{entry.data.description}</p>
        </header>

        <section class="mt-6 grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-4 gap-3">
          <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
            <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Event Snapshot</p>
            <p class="mt-2 text-sm">Event: <strong>{eventLabel}</strong></p>
            <p class="text-sm">Event date: <strong>{eventDate}</strong></p>
            <p class="text-sm">As-of (T-1): <strong>{asofDate}</strong></p>
            <p class="text-sm">Freshness age: <strong>{Number.isFinite(Number(freshnessDays)) ? `${Number(freshnessDays)} days` : '--'}</strong></p>
            <p class="text-sm">Sample size: <strong>{sampleSize}</strong></p>
          </div>

          <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
            <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Event Outcome</p>
            <p class="mt-2 text-sm">Direction: <strong>{eventDirection}</strong></p>
            <p class="text-sm">Actual: <strong>{eventActual ?? '--'}</strong></p>
            <p class="text-sm">Previous: <strong>{eventPrevious ?? '--'}</strong></p>
            <p class={`text-sm font-semibold ${Number(eventDelta) >= 0 ? 'metric-up' : 'metric-down'}`}>
              Delta: {Number.isFinite(Number(eventDelta)) ? Number(eventDelta).toFixed(4) : '--'}
            </p>
          </div>

          <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
            <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">All-history</p>
            <p class="mt-2 metric-up">P(up): <strong>{t1.up ?? '--'}%</strong></p>
            <p class="metric-down">P(down): <strong>{t1.down ?? '--'}%</strong></p>
            <p class="metric-muted">T+1 median: <strong>{t1.median ?? '--'}%</strong></p>
            <p class="metric-up mt-1">T+7 P(up): <strong>{t7.up ?? '--'}%</strong></p>
            <p class="metric-muted">T+7 median: <strong>{t7.median ?? '--'}%</strong></p>
          </div>

          <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
            <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Same-direction</p>
            <p class="mt-2 metric-up">T+1 P(up): <strong>{c1.up ?? '--'}%</strong></p>
            <p class="metric-down">T+1 P(down): <strong>{c1.down ?? '--'}%</strong></p>
            <p class="metric-up mt-1">T+7 P(up): <strong>{c7.up ?? '--'}%</strong></p>
            <p class="metric-down">T+7 P(down): <strong>{c7.down ?? '--'}%</strong></p>
            <p class="metric-muted">Matched sample: <strong>{conditionalSample}</strong></p>
          </div>
        </section>

        <section class="mt-4 rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
          <h2 class="text-base font-bold">Action Lens (Educational)</h2>
          <p class="mt-1 text-sm" style="color:var(--muted);">{signalText}</p>
        </section>

        <section class="mt-4 rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
          <h2 class="text-base font-bold">Similar Drawdown Events</h2>
          {similarPosts.length > 0 ? (
            <div class="mt-3 grid grid-cols-1 md:grid-cols-2 gap-3">
              {similarPosts.map((post) => (
                <a href={`/blog/${post.slug}`} class="rounded-lg border p-3 hover:translate-y-[-1px] transition-transform" style="border-color:var(--border);background:var(--surface);">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="badge-chip">{post.data.event_date || '--'}</span>
                    <span class={`text-xs font-bold ${post.data.signal === 'Bullish' ? 'metric-up' : post.data.signal === 'Bearish' ? 'metric-down' : 'metric-muted'}`}>
                      {post.data.signal || 'Neutral'}
                    </span>
                  </div>
                  <p class="mt-2 text-sm font-semibold leading-snug">{post.data.title}</p>
                  <p class="mt-1 text-xs" style="color:var(--muted);">
                    T+7 median: {post.data.probabilities?.t7?.median ?? '--'}% · sample: {post.data.probabilities?.sample_size ?? '--'}
                  </p>
                </a>
              ))}
            </div>
          ) : (
            <p class="mt-2 text-sm" style="color:var(--muted);">No close historical drawdown matches were found for this asset/event pair yet.</p>
          )}
        </section>

        {entry.data.chartData && entry.data.chartData.length > 0 && (
          <div class="mt-6">
            <TradingChart data={entry.data.chartData} asset={entry.data.tags?.[0]} title={`${entry.data.tags?.[0]?.toUpperCase()} Price (Event Window)`} />
          </div>
        )}

        <div class="prose prose-slate max-w-none mt-6">
          <Content />
        </div>

        <DynamicCta asset={entry.data.tags?.[0] || 'BTC'} slug={entry.slug} />
      </article>

      {relatedPosts.length > 0 && (
        <section class="mt-8">
          <h3 class="text-xl font-bold mb-3">Related Research</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {relatedPosts.map((post) => (
              <a href={`/blog/${post.slug}`} class="surface-card p-4">
                <p class="text-xs font-bold mb-2" style="color:var(--muted);">{post.data.event_label || post.data.event_type}</p>
                <h4 class="text-sm font-semibold leading-snug">{post.data.title}</h4>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>
  </section>
</Layout>
