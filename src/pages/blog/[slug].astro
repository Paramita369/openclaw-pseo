---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const { entry } = Astro.props;
const { Content } = await entry.render();

// Get related posts (same asset)
const allPosts = await getCollection('blog');
const asset = entry.data.tags?.[0] || 'OTHER';
const relatedPosts = allPosts
    .filter(p => p.data.tags?.[0] === asset && p.slug !== entry.slug)
    .slice(0, 3);
---

<Layout title={entry.data.title} description={entry.data.description}>
    <article class="max-w-4xl mx-auto py-8">
        <!-- Header -->
        <header class="mb-8">
            <div class="flex gap-2 mb-4">
                {entry.data.tags?.map(tag => (
                    <span class="bg-indigo-100 text-indigo-800 px-3 py-1 rounded-full text-sm font-medium">{tag}</span>
                ))}
            </div>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{entry.data.title}</h1>
            <p class="text-gray-600 text-lg">{entry.data.description}</p>
            <p class="text-gray-500 mt-2">Published: {entry.data.pubDate}</p>
        </header>
        
        <!-- Main Content -->
        <div class="prose prose-lg max-w-none prose-indigo">
            <Content />
        </div>
        
        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
            <section class="mt-12 pt-8 border-t">
                <h2 class="text-2xl font-bold mb-6">Related Analysis</h2>
                <div class="grid md:grid-cols-3 gap-4">
                    {relatedPosts.map(post => (
                        <a href={`/blog/${post.slug}`} class="block bg-white p-4 rounded-lg shadow hover:shadow-md transition border border-gray-200">
                            <h3 class="font-medium text-gray-900 line-clamp-2">{post.data.title}</h3>
                            <p class="text-sm text-gray-500 mt-2">{post.data.pubDate}</p>
                        </a>
                    ))}
                </div>
            </section>
        )}
        
        <!-- Sticky CTA Banner -->
        <div class="fixed bottom-0 left-0 right-0 bg-indigo-600 text-white py-4 px-6 shadow-lg transform transition-transform duration-300 z-50">
            <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="text-center md:text-left">
                    <span class="font-bold">Start Trading Today</span>
                    <span class="text-indigo-200 text-sm ml-2">Get exclusive referral bonuses</span>
                </div>
                <div class="flex gap-3">
                    <a href="https://www.binance.com/referral/earn-together/refer2earn-usdc/claim?hl=zh-TC&ref=GRO_28502_NXG80" 
                       target="_blank"
                       class="bg-white text-indigo-600 px-4 py-2 rounded-lg font-medium hover:bg-indigo-50 transition">
                        Binance
                    </a>
                    <a href="https://invest.futuhk.com/invite-centre_share?lang=zh-hk&invite_code=MQHETN7N" 
                       target="_blank"
                       class="bg-indigo-500 text-white px-4 py-2 rounded-lg font-medium hover:bg-indigo-400 transition">
                        Futu
                    </a>
                </div>
            </div>
        </div>
        
        <!-- Footer Disclaimer -->
        <footer class="mt-16 pt-8 border-t text-sm text-gray-500">
            <p class="text-center">
                <strong>Disclaimer:</strong> This content is for educational purposes only. Trading involves substantial risk. 
                Past performance does not guarantee future results. Always conduct your own research before making investment decisions.
            </p>
            <p class="text-center mt-2">
                QuantMacro Analytics &copy; 2026. Data updated daily.
            </p>
        </footer>
    </article>
</Layout>

<style>
    /* Custom prose styling for data tables */
    .prose table {
        width: 100%;
        border-collapse: collapse;
    }
    .prose th {
        background: #f8fafc;
        font-weight: 600;
        text-align: left;
        padding: 12px;
        border: 1px solid #e2e8f0;
    }
    .prose td {
        padding: 12px;
        border: 1px solid #e2e8f0;
    }
    /* Positive values green */
    .prose td:contains('+') {
        color: #16a34a;
        font-weight: 500;
    }
    /* Negative values red */
    .prose td:contains('-') {
        color: #dc2626;
        font-weight: 500;
    }
</style>
