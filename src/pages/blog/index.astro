---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const sortedPosts = [...posts].sort((a, b) => {
  const ad = a.data.event_date || a.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
  const bd = b.data.event_date || b.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
  return bd.localeCompare(ad);
});

const assetCounts = {};
const eventCounts = {};
for (const post of sortedPosts) {
  const asset = (post.data.tags?.[0] || 'other').toLowerCase();
  const event = String(post.data.event_type || '').toLowerCase();
  assetCounts[asset] = (assetCounts[asset] || 0) + 1;
  eventCounts[event] = (eventCounts[event] || 0) + 1;
}

const assets = Object.keys(assetCounts).sort();
const events = ['cpi', 'nfp', 'fomc'];
---

<Layout title="Event Research Archive" description="QuantMacro archive for CPI/NFP/FOMC event-driven probability pages.">
  <section class="py-12 hero-panel">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-extrabold text-white">Event Research Archive</h1>
      <p class="text-blue-100 mt-3 text-lg">
        {sortedPosts.length} pages · use asset hubs and event hubs for focused navigation.
      </p>
      <div class="mt-4 flex flex-wrap gap-2">
        <a href="/events" class="btn-ghost" style="border-color:rgba(255,255,255,.4);color:#f2f6ff;">Open Event Hubs</a>
        <a href="/tags/btc" class="btn-ghost" style="border-color:rgba(255,255,255,.4);color:#f2f6ff;">Open Asset Hubs</a>
      </div>
    </div>
  </section>

  <section class="py-6 border-b" style="border-color:var(--border);background:var(--surface);">
    <div class="max-w-6xl mx-auto px-4 space-y-4">
      <div>
        <p class="text-xs font-bold uppercase tracking-wide mb-2" style="color:var(--muted);">Asset Hubs</p>
        <div class="flex flex-wrap gap-2">
          {assets.map((asset) => (
            <a href={`/tags/${asset}`} class="badge-chip" data-track-event="filter_apply" data-filter={asset}>
              {asset.toUpperCase()} ({assetCounts[asset]})
            </a>
          ))}
        </div>
      </div>

      <div>
        <p class="text-xs font-bold uppercase tracking-wide mb-2" style="color:var(--muted);">Event Hubs</p>
        <div class="flex flex-wrap gap-2">
          {events.map((event) => (
            <a href={`/events/${event}`} class="badge-chip" data-track-event="filter_apply" data-filter={event}>
              {event.toUpperCase()} ({eventCounts[event] || 0})
            </a>
          ))}
        </div>
      </div>

      <div>
        <label for="archive-search" class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Archive Search</label>
        <input
          id="archive-search"
          type="search"
          placeholder="Search by asset, event, signal, or date..."
          class="mt-2 w-full rounded-xl border px-3 py-2 text-sm"
          style="border-color:var(--border);background:var(--surface-alt);"
        />
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <div id="archive-grid" class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
      {sortedPosts.map((post, idx) => {
        const signal = post.data.signal || 'Neutral';
        const signalClass = signal === 'Bullish' ? 'metric-up' : signal === 'Bearish' ? 'metric-down' : 'metric-muted';
        const probs = post.data.probabilities;
        const searchable = [
          post.data.tags?.[0],
          post.data.event_type,
          post.data.signal,
          post.data.event_date,
          post.data.title,
          post.data.event_direction,
        ]
          .filter(Boolean)
          .join(' ')
          .toLowerCase();

        return (
          <a
            href={`/blog/${post.slug}`}
            class="surface-card p-5 flex flex-col gap-3 hover:translate-y-[-2px] transition-transform archive-card"
            data-search={searchable}
            data-order={idx}
          >
            <div class="flex flex-wrap items-center gap-2">
              <span class="badge-chip">{post.data.tags?.[0]?.toUpperCase()}</span>
              <span class="badge-chip">{post.data.event_label || post.data.event_type}</span>
              <span class="badge-chip">{post.data.event_direction?.toUpperCase() || '--'}</span>
              <span class={`text-xs font-bold ${signalClass}`}>{signal}</span>
            </div>

            <h2 class="text-lg font-bold leading-snug">{post.data.title}</h2>
            <p class="text-sm" style="color:var(--muted);">{post.data.description}</p>

            <div class="grid grid-cols-2 gap-2 text-xs">
              <div class="rounded-lg border p-2" style="border-color:var(--border);background:var(--surface-alt);">
                <p class="font-bold">T+1 P(up)</p>
                <p class="metric-up">{probs?.t1?.up ?? '--'}%</p>
              </div>
              <div class="rounded-lg border p-2" style="border-color:var(--border);background:var(--surface-alt);">
                <p class="font-bold">T+7 P(up)</p>
                <p class="metric-up">{probs?.t7?.up ?? '--'}%</p>
              </div>
            </div>

            <div class="mt-auto text-xs" style="color:var(--muted);">
              Event date: {post.data.event_date || '--'} · As-of: {post.data.asof_date || '--'}
            </div>
          </a>
        );
      })}
    </div>
    <div class="mt-6 flex items-center justify-center">
      <button id="archive-load-more" type="button" class="btn-ghost text-sm">Load More</button>
    </div>
    <p id="archive-empty" class="hidden mt-6 text-sm" style="color:var(--muted);">No pages match the current search.</p>
  </section>

  <script is:inline>
    (() => {
      const input = document.getElementById('archive-search');
      const cards = Array.from(document.querySelectorAll('.archive-card'));
      const loadMore = document.getElementById('archive-load-more');
      const empty = document.getElementById('archive-empty');
      const pageSize = 30;
      let visibleLimit = pageSize;

      const apply = () => {
        const query = (input?.value || '').trim().toLowerCase();
        let visible = 0;
        let shown = 0;

        cards.forEach((card) => {
          const searchable = card.getAttribute('data-search') || '';
          const matchQuery = !query || searchable.includes(query);
          if (!matchQuery) {
            card.classList.add('hidden');
            return;
          }

          visible += 1;
          shown += 1;
          const shouldShow = shown <= visibleLimit;
          card.classList.toggle('hidden', !shouldShow);
        });

        empty?.classList.toggle('hidden', visible > 0);
        if (loadMore) {
          const hasMore = visible > visibleLimit;
          loadMore.classList.toggle('hidden', !hasMore);
        }
      };

      loadMore?.addEventListener('click', () => {
        visibleLimit += pageSize;
        apply();
      });
      input?.addEventListener('input', () => {
        visibleLimit = pageSize;
        apply();
      });
      apply();
    })();
  </script>
</Layout>
