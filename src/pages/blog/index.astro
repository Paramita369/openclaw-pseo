---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const sortedPosts = [...posts].sort((a, b) => {
  const ad = a.data.event_date || a.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
  const bd = b.data.event_date || b.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
  return bd.localeCompare(ad);
});

const assetCounts = {};
for (const post of sortedPosts) {
  const asset = (post.data.tags?.[0] || 'other').toLowerCase();
  assetCounts[asset] = (assetCounts[asset] || 0) + 1;
}
const assets = Object.keys(assetCounts).sort();

const url = new URL(Astro.request.url);
const assetParam = url.searchParams.get('asset')?.toLowerCase() || '';

const filtered = assetParam
  ? sortedPosts.filter((post) => (post.data.tags?.[0] || '').toLowerCase() === assetParam)
  : sortedPosts;
---

<Layout title={assetParam ? `${assetParam.toUpperCase()} Event Research` : 'All Event Research'} description="QuantMacro archive for CPI/NFP/FOMC event-driven probability pages.">
  <section class="py-12 hero-panel">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-extrabold text-white">
        {assetParam ? `${assetParam.toUpperCase()} Event Research` : 'All Event Research'}
      </h1>
      <p class="text-blue-100 mt-3 text-lg">
        {filtered.length} pages · event-driven probabilities across CPI, NFP, and FOMC.
      </p>
    </div>
  </section>

  <section class="py-6 border-b" style="border-color:var(--border);background:var(--surface);">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-wrap gap-2">
        <a
          href="/blog"
          class={`badge-chip ${assetParam ? '' : 'font-extrabold'}`}
          data-track-event="filter_apply"
          data-filter="all"
        >
          All ({sortedPosts.length})
        </a>
        {assets.map((asset) => (
          <a
            href={`/blog?asset=${asset}`}
            class={`badge-chip ${assetParam === asset ? 'font-extrabold' : ''}`}
            data-track-event="filter_apply"
            data-filter={asset}
          >
            {asset.toUpperCase()} ({assetCounts[asset]})
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-4">
      {filtered.map((post) => {
        const signal = post.data.signal || 'Neutral';
        const signalClass = signal === 'Bullish' ? 'metric-up' : signal === 'Bearish' ? 'metric-down' : 'metric-muted';
        const probs = post.data.probabilities;

        return (
          <a href={`/blog/${post.slug}`} class="surface-card p-5 flex flex-col gap-3 hover:translate-y-[-2px] transition-transform">
            <div class="flex flex-wrap items-center gap-2">
              <span class="badge-chip">{post.data.tags?.[0]?.toUpperCase()}</span>
              <span class="badge-chip">{post.data.event_label || post.data.event_type}</span>
              <span class={`text-xs font-bold ${signalClass}`}>{signal}</span>
            </div>

            <h2 class="text-lg font-bold leading-snug">{post.data.title}</h2>
            <p class="text-sm" style="color:var(--muted);">{post.data.description}</p>

            <div class="grid grid-cols-2 gap-2 text-xs">
              <div class="rounded-lg border p-2" style="border-color:var(--border);background:var(--surface-alt);">
                <p class="font-bold">T+1 P(up)</p>
                <p class="metric-up">{probs?.t1?.up ?? '--'}%</p>
              </div>
              <div class="rounded-lg border p-2" style="border-color:var(--border);background:var(--surface-alt);">
                <p class="font-bold">T+7 P(up)</p>
                <p class="metric-up">{probs?.t7?.up ?? '--'}%</p>
              </div>
            </div>

            <div class="mt-auto text-xs" style="color:var(--muted);">
              Event date: {post.data.event_date || '--'} · As-of: {post.data.asof_date || '--'}
            </div>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
