---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Get asset query param
const url = new URL(Astro.request.url);
const assetFilter = url.searchParams.get('asset')?.toUpperCase();

// Filter by asset if specified
const filteredPosts = assetFilter 
    ? posts.filter(p => (p.data.tags?.[0] || '').toUpperCase() === assetFilter)
    : posts;

// Group by asset
const assets = {};
filteredPosts.forEach(post => {
  const asset = (post.data.tags?.[0] || 'OTHER').toUpperCase();
  if (!assets[asset]) {
    assets[asset] = [];
  }
  assets[asset].push(post);
});

const assetList = Object.keys(assets).sort();
---

<Layout title={assetFilter ? `${assetFilter} Analysis` : "All Analysis"} description="QuantMacro Analytics - Historical price impact analysis">
    <section class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-16">
        <div class="max-w-6xl mx-auto px-4 text-center">
            <h1 class="text-4xl font-bold mb-4">
                {assetFilter ? `${assetFilter} Analysis` : 'All Analysis'}
            </h1>
            <p class="text-xl text-indigo-100">
                {filteredPosts.length} quantitative analysis articles
                {assetFilter ? ` for ${assetFilter}` : ''}
            </p>
        </div>
    </section>
    
    <!-- Asset Filter Tabs -->
    <div class="bg-white shadow-sm border-b">
        <div class="max-w-6xl mx-auto px-4 py-4 overflow-x-auto">
            <div class="flex gap-2">
                <a href="/blog" class={`px-4 py-2 rounded-full text-sm font-medium transition ${!assetFilter ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
                    All
                </a>
                {assetList.map(asset => (
                    <a href={`/blog?asset=${asset.toLowerCase()}`} 
                       class={`px-4 py-2 rounded-full text-sm font-medium transition ${assetFilter === asset ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
                        {asset}
                    </a>
                ))}
            </div>
        </div>
    </div>
    
    <!-- Posts Grid -->
    <section class="max-w-6xl mx-auto px-4 py-12">
        {assetFilter && (
            <div class="mb-8">
                <a href="/blog" class="text-indigo-600 hover:text-indigo-800 font-medium">
                    ← Back to all assets
                </a>
            </div>
        )}
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {filteredPosts.map(post => (
                <a href={`/blog/${post.slug}`} class="block bg-white rounded-xl shadow-sm hover:shadow-lg transition border border-gray-200 overflow-hidden group">
                    <div class="p-6">
                        <div class="flex gap-2 mb-3">
                            {post.data.tags?.slice(0, 2).map(tag => (
                                <span class="bg-indigo-50 text-indigo-700 px-2 py-1 rounded text-xs font-medium">{tag}</span>
                            ))}
                        </div>
                        <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-indigo-600 transition line-clamp-2">
                            {post.data.title}
                        </h2>
                        <p class="text-gray-600 text-sm line-clamp-3 mb-4">
                            {post.data.description}
                        </p>
                        <div class="flex items-center justify-between text-sm text-gray-500">
                            <span>{post.data.pubDate}</span>
                            <span class="text-indigo-600 font-medium group-hover:translate-x-1 transition">
                                Read more →
                            </span>
                        </div>
                    </div>
                </a>
            ))}
        </div>
        
        {filteredPosts.length === 0 && (
            <div class="text-center py-12">
                <p class="text-gray-500 text-lg">No articles found for this asset.</p>
                <a href="/blog" class="text-indigo-600 hover:text-indigo-800 font-medium mt-4 inline-block">
                    View all articles →
                </a>
            </div>
        )}
    </section>
</Layout>
