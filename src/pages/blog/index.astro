---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<Layout title="Analysis | OpenClaw Analytics" description="Historical data analysis for crypto, stocks, and macro events">
    <section class="text-center py-12">
        <h1 class="text-4xl font-bold mb-4">Analysis</h1>
        <p class="text-xl text-gray-600 mb-8">Historical price impact analysis for macro events</p>
    </section>
    
    <section class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="block bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
                <h2 class="text-xl font-bold mb-2">{post.data.title}</h2>
                <p class="text-gray-600 text-sm mb-4">{post.data.description}</p>
                <div class="flex gap-2 flex-wrap">
                    {post.data.tags?.map(tag => (
                        <span class="bg-indigo-100 text-indigo-800 px-2 py-1 rounded text-xs">{tag}</span>
                    ))}
                </div>
                <p class="text-gray-500 text-sm mt-4">{post.data.pubDate}</p>
            </a>
        ))}
    </section>
</Layout>
