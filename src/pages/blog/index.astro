---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Get all unique assets
const allAssets = {};
posts.forEach(post => {
  const asset = (post.data.tags?.[0] || 'other').toLowerCase();
  allAssets[asset] = (allAssets[asset] || 0) + 1;
});
const assetList = Object.keys(allAssets).sort();

// Get asset from URL
const url = new URL(Astro.request.url);
const assetParam = url.searchParams.get('asset')?.toLowerCase();
---

<Layout title={assetParam ? assetParam.toUpperCase() + " Analysis" : "All Analysis"}>
  <section class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl font-bold mb-4">
        {assetParam ? assetParam.toUpperCase() : 'All'} Analysis
      </h1>
      <p class="text-xl text-indigo-100">
        {posts.length} quantitative analysis articles
      </p>
    </div>
  </section>
  
  <div class="bg-white shadow-sm border-b">
    <div class="max-w-6xl mx-auto px-4 py-4 overflow-x-auto">
      <div class="flex gap-2">
        <a href="/blog" class={`px-4 py-2 rounded-full text-sm font-medium transition ${!assetParam ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
          All
        </a>
        {assetList.map(asset => (
          <a href={`/tags/${asset}`} class={`px-4 py-2 rounded-full text-sm font-medium transition ${assetParam === asset ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}`}>
            {asset.toUpperCase()}
          </a>
        ))}
      </div>
    </div>
  </div>
  
  <section class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="block bg-white rounded-xl shadow-sm hover:shadow-lg transition border border-gray-200 overflow-hidden">
          <div class="p-6">
            <div class="flex gap-2 mb-3">
              {post.data.tags?.slice(0, 2).map(tag => (
                <span class="bg-indigo-50 text-indigo-700 px-2 py-1 rounded text-xs font-medium">{tag}</span>
              ))}
            </div>
            <h2 class="text-lg font-bold text-gray-900 mb-2 line-clamp-2">{post.data.title}</h2>
            <p class="text-gray-600 text-sm line-clamp-2 mb-4">{post.data.description}</p>
            <div class="flex items-center justify-between text-sm text-gray-500">
              <span>{post.data.pubDate}</span>
              <span class="text-indigo-600 font-medium">Read more →</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>
