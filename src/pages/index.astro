---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Read all generated Markdown files
const posts = await getCollection('blog');

// 2. Group by asset (first tag)
const assetGroups = {};
posts.forEach(post => {
  const tags = post.data.tags || [];
  const asset = (tags[0] || 'Other').toUpperCase();
  if (!assetGroups[asset]) {
    assetGroups[asset] = [];
  }
  // Max 5 per asset for homepage
  if (assetGroups[asset].length < 5) {
    assetGroups[asset].push(post);
  }
});

// 3. Sort assets
const assets = Object.keys(assetGroups).sort();
---

<Layout title="QuantMacro Dashboard" description="Quantitative backtesting data for cross-asset volatility post-macro events">
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <header class="mb-12 border-b border-gray-200 pb-8">
            <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">QuantMacro Dashboard</h1>
            <p class="mt-4 text-xl text-gray-500">
                Quantitative backtesting data for cross-asset volatility post-macro events. Data driven trading insights.
            </p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {assets.map(asset => (
                <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden flex flex-col">
                    <div class="bg-slate-50 px-6 py-4 border-b border-gray-200 flex justify-between items-center">
                        <h2 class="text-xl font-bold text-slate-800">{asset} Markets</h2>
                        <span class="px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Data</span>
                    </div>
                    <ul class="divide-y divide-gray-100 flex-grow">
                        {assetGroups[asset].map(post => (
                            <li>
                                <a href={`/blog/${post.slug}`} class="block px-6 py-4 hover:bg-slate-50 transition-colors duration-150">
                                    <span class="text-sm font-medium text-slate-700 hover:text-blue-600 line-clamp-2">
                                        {post.data.title}
                                    </span>
                                </a>
                            </li>
                        ))}
                    </ul>
                    <div class="px-6 py-3 bg-gray-50 border-t">
                        <a href={`/blog?asset=${asset.toLowerCase()}`} class="text-sm text-blue-600 hover:text-blue-800 font-medium">
                            View all {posts.filter(p => (p.data.tags?.[0] || '').toUpperCase() === asset).length} {asset} articles →
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </main>
</Layout>
