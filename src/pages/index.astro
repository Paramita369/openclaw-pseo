---
import Layout from '../layouts/Layout.astro';
---

<Layout title="OpenClaw Quantitative Analytics" description="Data-driven trading insights for crypto, stocks, and macro events">
    <section class="text-center py-16">
        <h1 class="text-5xl font-bold mb-4">OpenClaw Analytics</h1>
        <p class="text-xl text-gray-600 mb-8">Data-driven trading insights for macro events</p>
        <div class="flex justify-center gap-4">
            <a href="/blog" class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700">View Analysis</a>
        </div>
    </section>
    
    <section class="grid md:grid-cols-3 gap-8 mt-12">
        <div class="bg-white p-6 rounded-lg shadow">
            <h3 class="text-xl font-bold mb-2">📊 Historical Data</h3>
            <p class="text-gray-600">Track historical price reactions to macro events</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
            <h3 class="text-xl font-bold mb-2">🎯 Predictions</h3>
            <p class="text-gray-600">Data-backed insights for trading decisions</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow">
            <h3 class="text-xl font-bold mb-2">🔄 Real-time Updates</h3>
            <p class="text-gray-600">Automated analysis as new data arrives</p>
        </div>
    </section>
</Layout>
