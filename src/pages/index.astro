---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import dailySnapshot from '../daily_snapshot.json';
import offersConfig from '../data/offers.json';

const posts = await getCollection('blog');
const markets = dailySnapshot.markets || {};

const parseIsoDate = (value) => {
  const text = String(value || '').slice(0, 10);
  if (!text) return null;
  const parsed = new Date(`${text}T00:00:00Z`);
  return Number.isNaN(parsed.getTime()) ? null : parsed;
};

const sortedPosts = [...posts].sort((a, b) => {
  const ad = a.data.event_date || a.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
  const bd = b.data.event_date || b.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
  return bd.localeCompare(ad);
});

const preferredAssets = ['BTC', 'ETH', 'GOLD', 'QQQ', 'SPY'];
const latestByAsset = {};
for (const entry of sortedPosts) {
  const asset = String(entry.data.tags?.[0] || '').toUpperCase();
  if (!asset || latestByAsset[asset]) continue;
  latestByAsset[asset] = entry;
}

const playbookRows = preferredAssets
  .map((asset) => {
    const entry = latestByAsset[asset];
    if (!entry) return null;

    const p = entry.data.probabilities || null;
    const t1Up = p?.t1?.up;
    const t1Down = p?.t1?.down;
    const t7Up = p?.t7?.up;
    const t7Down = p?.t7?.down;
    const t1Median = p?.t1?.median;
    const t7Median = p?.t7?.median;
    const sampleSize = p?.sample_size ?? p?.t1?.sample ?? entry.data.sample_size ?? 0;

    const signal =
      entry.data.signal ||
      ((entry.data.metrics?.impact_t7_pct || 0) > 1
        ? 'Bullish'
        : (entry.data.metrics?.impact_t7_pct || 0) < -1
          ? 'Bearish'
          : 'Neutral');

    return {
      asset,
      entry,
      signal,
      sampleSize,
      event: entry.data.event_label || entry.data.event_type || 'CPI',
      eventDate: entry.data.event_date || entry.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '',
      asofDate:
        entry.data.asof_date || (dailySnapshot.timestamp ? new Date(dailySnapshot.timestamp).toISOString().slice(0, 10) : ''),
      t1Up,
      t1Down,
      t7Up,
      t7Down,
      t1Median,
      t7Median,
    };
  })
  .filter(Boolean);

const latestEventDate = playbookRows.map((row) => row.eventDate).filter(Boolean).sort().at(-1) || '';
const latestAsOfDate =
  playbookRows.map((row) => row.asofDate).filter(Boolean).sort().at(-1) ||
  (dailySnapshot.timestamp ? new Date(dailySnapshot.timestamp).toISOString().slice(0, 10) : '');
const latestEventDt = parseIsoDate(latestEventDate);
const latestAsOfDt = parseIsoDate(latestAsOfDate) || new Date();
const latestRow = [...playbookRows]
  .filter((row) => row.eventDate)
  .sort((a, b) => String(b.eventDate).localeCompare(String(a.eventDate)))[0];
const freshnessThresholds = { CPI: 45, NFP: 45, FOMC: 90 };
const latestEventType = String(latestRow?.event || '').toUpperCase();
const freshnessThreshold = freshnessThresholds[latestEventType] || 45;
const freshnessAgeDays = latestEventDt
  ? Math.max(Math.floor((latestAsOfDt.getTime() - latestEventDt.getTime()) / (1000 * 60 * 60 * 24)), 0)
  : 0;
const isStalePlaybook = Boolean(latestEventDt) && freshnessAgeDays > freshnessThreshold;
const playbookHeading = isStalePlaybook ? 'Latest Event Playbook' : 'Current Event Playbook';
const playbookSubline = isStalePlaybook
  ? `Last event: ${latestEventDate} (age ${freshnessAgeDays} days). Showing latest validated playbook.`
  : 'Probabilities are generated from historical CPI/NFP/FOMC event windows.';

const utmSource = offersConfig.utm?.source || 'quantmacro';
const utmMedium = offersConfig.utm?.medium || 'affiliate';

const resolveOfferSet = (asset) => {
  const fallbackKeys = offersConfig.asset_offer_keys?.[asset] || offersConfig.asset_offer_keys?.DEFAULT || [];
  const primaryKey =
    offersConfig.primary_offer_keys?.[asset] ||
    offersConfig.primary_offer_keys?.DEFAULT ||
    fallbackKeys[0] ||
    'ibkr';
  const secondaryKeys = (offersConfig.secondary_offer_keys?.[asset] || offersConfig.secondary_offer_keys?.DEFAULT || [])
    .filter((key) => key && key !== primaryKey);

  const primaryOffer = primaryKey && offersConfig.offers?.[primaryKey] ? { key: primaryKey, ...offersConfig.offers[primaryKey] } : null;
  const secondaryOffers = secondaryKeys
    .map((key) => ({ key, ...offersConfig.offers?.[key] }))
    .filter((offer) => Boolean(offer && offer.url));

  const attachTracking = (offer, role) => {
    const url = new URL(offer.url);
    url.searchParams.set('utm_source', utmSource);
    url.searchParams.set('utm_medium', utmMedium);
    url.searchParams.set('utm_campaign', offer.utm_campaign || `affiliate_${offer.key}`);
    url.searchParams.set('utm_content', `dashboard_${asset.toLowerCase()}_${role}`);
    return { ...offer, trackedUrl: url.toString() };
  };

  return {
    primary: primaryOffer ? attachTracking(primaryOffer, 'primary') : null,
    secondary: secondaryOffers.map((offer) => attachTracking(offer, 'secondary')),
  };
};

const steps = [
  {
    title: 'Step 1 · Pick Asset',
    body: 'Start with BTC, ETH, GOLD, QQQ, or SPY based on your market focus.',
  },
  {
    title: 'Step 2 · Read Event Probabilities',
    body: 'Use T+1 and T+7 up/down probabilities with sample size and median return.',
  },
  {
    title: 'Step 3 · Execute via Platform',
    body: 'Use the matched broker/exchange link with tracking and consistent UTM tags.',
  },
];
---

<Layout title="QuantMacro Dashboard" description="Event-driven probabilities for CPI, NFP, and FOMC across major assets.">
  <section class="hero-panel py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <p class="badge-chip mb-4" style="background:rgba(255,255,255,.16);border-color:rgba(255,255,255,.25);color:#e5ecfb;">QuantMacro V2</p>
        <h1 class="text-4xl md:text-5xl font-extrabold leading-tight text-white">
          Event-Driven Return Probabilities You Can Act On in Seconds
        </h1>
        <div class="mt-6 space-y-2 text-blue-100 text-lg">
          <p><strong>What:</strong> CPI / NFP / FOMC probability playbooks by asset.</p>
          <p><strong>Why:</strong> Backtested on historical event windows with sample size transparency.</p>
          <p><strong>How:</strong> Pick asset → Read odds → Open execution platform.</p>
        </div>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#playbook" class="btn-primary focus-ring" data-track-event="playbook_open" data-surface="hero">Open Playbook</a>
          <a href="/events" class="btn-ghost focus-ring" style="border-color:rgba(255,255,255,.4);color:#f2f6ff;">Open Event Hubs</a>
          <a href="/blog" class="btn-ghost focus-ring" style="border-color:rgba(255,255,255,.4);color:#f2f6ff;">Browse All Research</a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-10">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-5">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {steps.map((step) => (
          <div class="surface-card p-5">
            <h3 class="text-base font-bold mb-2">{step.title}</h3>
            <p style="color:var(--muted);">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-2">
    <div class="max-w-7xl mx-auto px-4">
      <div class="surface-card p-4 md:p-5">
        <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
          <h2 class="text-xl font-bold">Market Snapshot</h2>
          <span class="text-sm" style="color:var(--muted);">
            {dailySnapshot.timestamp ? new Date(dailySnapshot.timestamp).toLocaleString() : 'No snapshot timestamp'}
          </span>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-3">
          {Object.entries(markets).map(([name, data]) => {
            const positive = data.change >= 0;
            return (
              <div class="rounded-xl border p-3" style="border-color:var(--border);background:var(--surface-alt);">
                <p class="text-xs font-semibold" style="color:var(--muted);">{name}</p>
                <p class="text-lg font-bold mt-1">{typeof data.price === 'number' ? data.price.toLocaleString() : data.price}</p>
                <p class={`text-sm font-semibold mt-1 ${positive ? 'metric-up' : 'metric-down'}`}>
                  {positive ? '+' : ''}{data.change}%
                </p>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <section id="playbook" class="py-10">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-wrap items-end justify-between gap-3 mb-4">
        <div>
          <h2 class="text-2xl font-bold">{playbookHeading}</h2>
          <p class="text-sm mt-1" style="color:var(--muted);">{playbookSubline}</p>
          {isStalePlaybook && (
            <p class="text-xs mt-1">
              <span class="stale-data-label">Stale Data</span> showing latest available release set, not a same-day event.
            </p>
          )}
        </div>
        <a class="btn-ghost focus-ring" href="/leaderboard">Open Full Playbook</a>
      </div>

      <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
        {playbookRows.map((row) => {
          const offerSet = resolveOfferSet(row.asset);
          const signalClass = row.signal === 'Bullish' ? 'metric-up' : row.signal === 'Bearish' ? 'metric-down' : 'metric-muted';
          return (
            <article class="surface-card p-5">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <div class="flex items-center gap-2">
                  <h3 class="text-xl font-bold">{row.asset}</h3>
                  <span class="badge-chip">{row.event}</span>
                  <span class="badge-chip">{row.entry.data.event_direction?.toUpperCase() || '--'}</span>
                  <span class={`text-sm font-bold ${signalClass}`}>{row.signal}</span>
                </div>
                <a
                  href={`/blog/${row.entry.slug}`}
                  class="btn-ghost text-sm focus-ring"
                  data-track-event="playbook_open"
                  data-asset={row.asset}
                  data-event={row.event}
                >
                  Open Analysis
                </a>
              </div>

              <div class="flex flex-wrap gap-2 mt-3">
                <a href={`/tags/${row.asset.toLowerCase()}`} class="badge-chip">Asset Hub</a>
                <a href={`/events/${String(row.event).toLowerCase()}`} class="badge-chip">Event Hub</a>
              </div>

              <div class="grid grid-cols-2 gap-3 mt-4 text-sm">
                <div class="rounded-xl border p-3" style="border-color:var(--border);background:var(--surface-alt);">
                  <p class="font-bold mb-2">T+1</p>
                  <p class="metric-up">P(up): {row.t1Up ?? '--'}%</p>
                  <p class="metric-down">P(down): {row.t1Down ?? '--'}%</p>
                  <p class="metric-muted">Median: {row.t1Median ?? '--'}%</p>
                </div>
                <div class="rounded-xl border p-3" style="border-color:var(--border);background:var(--surface-alt);">
                  <p class="font-bold mb-2">T+7</p>
                  <p class="metric-up">P(up): {row.t7Up ?? '--'}%</p>
                  <p class="metric-down">P(down): {row.t7Down ?? '--'}%</p>
                  <p class="metric-muted">Median: {row.t7Median ?? '--'}%</p>
                </div>
              </div>

              <div class="flex flex-wrap items-center justify-between gap-2 mt-4 text-sm" style="color:var(--muted);">
                <p>Sample size: <strong style="color:var(--text);">{row.sampleSize || '--'}</strong></p>
                <p>
                  Event date: <strong style="color:var(--text);">{row.eventDate || '--'}</strong> · As-of:{' '}
                  <strong style="color:var(--text);">{row.asofDate || '--'}</strong>
                </p>
              </div>

              {offerSet?.primary && (
                <div class="mt-4 flex flex-wrap items-center justify-between gap-2">
                  <p class="text-sm" style="color:var(--muted);">Execution platform for {row.asset}</p>
                  <div class="flex flex-wrap gap-2">
                    <a
                      href={offerSet.primary.trackedUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      data-affiliate-click="1"
                      data-slug="homepage"
                      data-asset={row.asset}
                      data-offer-key={offerSet.primary.key}
                      data-cta-role="primary"
                      data-cta-variant="prominent"
                      data-cta-position="playbook_card"
                      data-utm-campaign={offerSet.primary.utm_campaign || `affiliate_${offerSet.primary.key}`}
                      class="btn-primary text-sm focus-ring"
                    >
                      Open {offerSet.primary.name}
                    </a>
                    {offerSet.secondary.map((offer) => (
                      <a
                        href={offer.trackedUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-affiliate-click="1"
                        data-slug="homepage"
                        data-asset={row.asset}
                        data-offer-key={offer.key}
                        data-cta-role="secondary"
                        data-cta-variant="muted"
                        data-cta-position="playbook_card"
                        data-utm-campaign={offer.utm_campaign || `affiliate_${offer.key}`}
                        class="btn-secondary-muted focus-ring"
                      >
                        Open {offer.name}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </article>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
