---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. Read all generated Markdown files
const posts = await getCollection('blog');

// 2. Group by asset (first tag)
const assetGroups = {};
posts.forEach(post => {
  const tags = post.data.tags || [];
  const asset = (tags[0] || 'Other').toUpperCase();
  if (!assetGroups[asset]) {
    assetGroups[asset] = [];
  }
  // Max 6 per asset for homepage
  if (assetGroups[asset].length < 6) {
    assetGroups[asset].push(post);
  }
});

// 3. Sort assets
const assets = Object.keys(assetGroups).sort();
---

<Layout title="QuantMacro Dashboard" description="Professional quantitative analysis for macro events">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-dark-bg via-dark-surface to-dark-bg py-20">
        <div class="absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-5"></div>
        <div class="max-w-7xl mx-auto px-4 relative z-10">
            <h1 class="text-5xl md:text-6xl font-bold text-white font-heading mb-4">
                <span class="text-primary">Quant</span>Macro
            </h1>
            <p class="text-xl text-gray-300 max-w-2xl mb-8">
                Professional quantitative analysis for macro events. 
                Data-driven trading insights with historical backtesting.
            </p>
            <div class="flex gap-4">
                <a href="/blog" class="bg-primary hover:bg-secondary text-dark-bg font-bold py-3 px-6 rounded-lg transition-all transform hover:scale-105">
                    Explore Analysis
                </a>
                <a href="#assets" class="border border-dark-border text-white hover:bg-dark-surface py-3 px-6 rounded-lg transition-all">
                    Browse Assets
                </a>
            </div>
        </div>
    </section>

    <!-- Stats Bar -->
    <section class="bg-dark-surface border-b border-dark-border py-6">
        <div class="max-w-7xl mx-auto px-4">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                <div class="text-center">
                    <div class="text-2xl font-bold text-primary font-heading">{posts.length}+</div>
                    <div class="text-gray-400 text-sm">Analysis Articles</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-white font-heading">{assets.length}</div>
                    <div class="text-gray-400 text-sm">Assets Tracked</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-profit font-heading">T+1</div>
                    <div class="text-gray-400 text-sm">Win Rate Tracking</div>
                </div>
                <div class="text-center">
                    <div class="text-2xl font-bold text-accent font-heading">24/7</div>
                    <div class="text-gray-400 text-sm">Data Updates</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Assets Grid -->
    <section id="assets" class="py-16 bg-dark-bg">
        <div class="max-w-7xl mx-auto px-4">
            <h2 class="text-3xl font-bold text-white font-heading mb-8">
                <span class="text-primary">Browse</span> by Asset
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {assets.map(asset => {
                    const colorClasses = {
                        'BTC': 'from-orange-500 to-amber-600',
                        'ETH': 'from-blue-500 to-indigo-600',
                        'SOL': 'from-purple-500 to-pink-600',
                        'GOLD': 'from-yellow-500 to-gold-600',
                        'SPY': 'from-green-500 to-emerald-600',
                        'DEFAULT': 'from-gray-500 to-slate-600'
                    };
                    const gradient = colorClasses[asset] || colorClasses['DEFAULT'];
                    
                    return (
                        <a href={`/blog?asset=${asset.toLowerCase()}`} 
                           class="group bg-dark-surface border border-dark-border rounded-xl overflow-hidden hover:border-primary/50 transition-all hover:shadow-lg hover:shadow-primary/10">
                            <div class={`h-2 bg-gradient-to-r ${gradient}`}></div>
                            <div class="p-6">
                                <div class="flex items-center justify-between mb-4">
                                    <h3 class="text-xl font-bold text-white font-heading group-hover:text-primary transition">
                                        {asset}
                                    </h3>
                                    <span class="bg-dark-bg text-gray-400 text-xs px-2 py-1 rounded">
                                        {posts.filter(p => (p.data.tags?.[0] || '').toUpperCase() === asset).length} articles
                                    </span>
                                </div>
                                <ul class="space-y-2">
                                    {assetGroups[asset].slice(0, 3).map(post => (
                                        <li class="text-gray-400 text-sm truncate hover:text-primary transition cursor-pointer">
                                            {post.data.title}
                                        </li>
                                    ))}
                                </ul>
                                <div class="mt-4 text-primary text-sm font-medium group-hover:translate-x-1 transition flex items-center">
                                    View all →
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 bg-gradient-to-r from-primary/10 to-accent/10 border-t border-dark-border">
        <div class="max-w-3xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold text-white font-heading mb-4">
                Start Trading Today
            </h2>
            <p class="text-gray-300 mb-8">
                Get exclusive referral bonuses on major trading platforms.
            </p>
            <div class="flex justify-center gap-4 flex-wrap">
                <a href="https://www.binance.com/referral/earn-together/refer2earn-usdc/claim?hl=zh-TC&ref=GRO_28502_NXG80" 
                   target="_blank"
                   class="bg-primary hover:bg-secondary text-dark-bg font-bold py-3 px-6 rounded-lg transition-all">
                    Binance
                </a>
                <a href="https://invest.futuhk.com/invite-centre_share?lang=zh-hk&invite_code=MQHETN7N" 
                   target="_blank"
                   class="bg-accent hover:bg-purple-600 text-white font-bold py-3 px-6 rounded-lg transition-all">
                    Futu
                </a>
            </div>
        </div>
    </section>
</Layout>
