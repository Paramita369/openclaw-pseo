---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Group posts by asset
const assets = {};
posts.forEach(post => {
  const asset = post.data.tags?.[0]?.toUpperCase() || 'OTHER';
  if (!assets[asset]) {
    assets[asset] = [];
  }
  assets[asset].push(post);
});

const assetList = Object.keys(assets).sort();
---

<Layout title="Home" description="QuantMacro Analytics - Data-driven trading insights for macro events">
    <section class="text-center py-12">
        <h1 class="text-5xl font-bold mb-4">QuantMacro Analytics</h1>
        <p class="text-xl text-gray-600 mb-8">Historical price impact analysis for macro events. Data-driven trading insights.</p>
        <div class="flex justify-center gap-4">
            <a href="/blog" class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700">View Analysis</a>
        </div>
    </section>
    
    <!-- Asset Categories Grid -->
    <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6 text-center">Browse by Asset</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {assetList.map(asset => (
                <a href={`/blog?asset=${asset.toLowerCase()}`} class="block bg-white p-6 rounded-lg shadow hover:shadow-lg transition border-l-4 border-indigo-500">
                    <h3 class="text-xl font-bold mb-2">{asset}</h3>
                    <p class="text-gray-600">{assets[asset].length} articles</p>
                </a>
            ))}
        </div>
    </section>
    
    <!-- Featured Analysis -->
    <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6 text-center">Latest Analysis</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {posts.slice(0, 6).map(post => (
                <a href={`/blog/${post.slug}`} class="block bg-white p-6 rounded-lg shadow hover:shadow-lg transition">
                    <h3 class="text-lg font-bold mb-2">{post.data.title}</h3>
                    <p class="text-gray-600 text-sm mb-4">{post.data.description}</p>
                    <div class="flex gap-2 flex-wrap">
                        {post.data.tags?.slice(0, 3).map(tag => (
                            <span class="bg-indigo-100 text-indigo-800 px-2 py-1 rounded text-xs">{tag}</span>
                        ))}
                    </div>
                </a>
            ))}
        </div>
    </section>
    
    <!-- Trust Signals -->
    <section class="bg-gray-100 rounded-lg p-8 text-center">
        <h2 class="text-2xl font-bold mb-4">Professional Quantitative Analysis</h2>
        <div class="grid md:grid-cols-3 gap-6">
            <div>
                <div class="text-3xl mb-2">📊</div>
                <h3 class="font-bold">Algorithmic Backtesting</h3>
                <p class="text-sm text-gray-600">Historical data-driven results</p>
            </div>
            <div>
                <div class="text-3xl mb-2">🔄</div>
                <h3 class="font-bold">Daily Updates</h3>
                <p class="text-sm text-gray-600">Data refreshed every day</p>
            </div>
            <div>
                <div class="text-3xl mb-2">📈</div>
                <h3 class="font-bold">Win Rate Tracking</h3>
                <p class="text-sm text-gray-600">T+1 / T+7 performance metrics</p>
            </div>
        </div>
    </section>
</Layout>
