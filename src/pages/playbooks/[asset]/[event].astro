---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import TrustSignals from '../../../components/TrustSignals.astro';
import { getCollection } from 'astro:content';
import { HUB_EVENTS, listHubRoutes, loadHubBriefs } from '../../../lib/hubBriefs';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const briefMap = loadHubBriefs({ strict: true });

  return listHubRoutes().map((route) => {
    const key = route.key;
    const brief = briefMap[key];
    const assetPosts = posts.filter((post) => String(post.data.tags?.[0] || '').toUpperCase() === route.asset);
    const latestPost = posts
      .filter((post) => {
        const asset = String(post.data.tags?.[0] || '').toUpperCase();
        const eventType = String(post.data.event_type || '').toUpperCase();
        return asset === route.asset && eventType === route.event;
      })
      .sort((a, b) => {
        const ad = a.data.event_date || a.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
        const bd = b.data.event_date || b.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
        return bd.localeCompare(ad);
      })[0];
    const crossEventRows = HUB_EVENTS.map((event) => {
      const latest = assetPosts
        .filter((post) => String(post.data.event_type || '').toUpperCase() === event)
        .sort((a, b) => {
          const ad = a.data.event_date || a.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
          const bd = b.data.event_date || b.slug.match(/(\d{4}-\d{2}-\d{2})$/)?.[1] || '1900-01-01';
          return bd.localeCompare(ad);
        })[0];
      return {
        event,
        eventDate: latest?.data?.event_date || '--',
        t1Up: latest?.data?.probabilities?.t1?.up ?? null,
        t7Up: latest?.data?.probabilities?.t7?.up ?? null,
        t7Median: latest?.data?.probabilities?.t7?.median ?? null,
        sample: latest?.data?.sample_size ?? null,
        slug: latest?.slug || '',
      };
    });

    return {
      params: { asset: route.asset.toLowerCase(), event: route.event.toLowerCase() },
      props: {
        asset: route.asset,
        eventType: route.event,
        brief,
        latestSlug: latestPost?.slug || '',
        latestEventDate: latestPost?.data?.event_date || '',
        crossEventRows,
      },
    };
  });
}

const { asset, eventType, brief, latestSlug, latestEventDate, crossEventRows = [] } = Astro.props;
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Strategy Hubs', url: '/playbooks' },
  { name: asset, url: `/tags/${asset.toLowerCase()}` },
  { name: eventType, url: `/playbooks/${asset.toLowerCase()}/${eventType.toLowerCase()}` },
];

const reviewedAt = brief?.reviewed_at || '--';
const status = String(brief?.status || 'draft').toLowerCase();
const indexing = String(brief?.indexing || (status === 'approved' ? 'index' : 'noindex')).toLowerCase();
const robotsDirective = indexing === 'index' ? 'index,follow' : 'noindex,follow';
const reviewedYear = String(reviewedAt).match(/^\d{4}/)?.[0] || String(new Date().getUTCFullYear());
const hubTitle = `${asset} ${eventType} Probability Playbook & Execution Guide (${reviewedYear} Update)`;
const siteUrl = 'https://quantmacro.vercel.app';
const hubPath = `/playbooks/${asset.toLowerCase()}/${eventType.toLowerCase()}`;
const hubUrl = `${siteUrl}${hubPath}`;
const hubVisualPayload = crossEventRows.map((row) => {
  const t1Up = Number(row.t1Up);
  const t7Up = Number(row.t7Up);
  const t7Median = Number(row.t7Median);
  const sample = Number(row.sample);
  return {
    event: String(row.event || '').toUpperCase(),
    eventDate: String(row.eventDate || '--'),
    t1Up: Number.isFinite(t1Up) ? t1Up : null,
    t7Up: Number.isFinite(t7Up) ? t7Up : null,
    t7Median: Number.isFinite(t7Median) ? t7Median : null,
    sample: Number.isFinite(sample) ? sample : null,
    slug: String(row.slug || ''),
  };
});
const validComparisonRows = hubVisualPayload.filter(
  (row) => typeof row.t1Up === 'number' && typeof row.t7Up === 'number' && typeof row.t7Median === 'number' && typeof row.sample === 'number'
);
const highestT7UpRow = [...validComparisonRows].sort((left, right) => (right.t7Up ?? -Infinity) - (left.t7Up ?? -Infinity))[0] || null;
const highestMedianRow = [...validComparisonRows].sort((left, right) => (right.t7Median ?? -Infinity) - (left.t7Median ?? -Infinity))[0] || null;
const deepestSampleRow = [...validComparisonRows].sort((left, right) => (right.sample ?? -Infinity) - (left.sample ?? -Infinity))[0] || null;
const currentEventRow = validComparisonRows.find((row) => row.event === eventType) || null;
const t7Rank = currentEventRow
  ? [...validComparisonRows]
      .sort((left, right) => (right.t7Up ?? -Infinity) - (left.t7Up ?? -Infinity))
      .findIndex((row) => row.event === eventType) + 1
  : 0;
const medianRank = currentEventRow
  ? [...validComparisonRows]
      .sort((left, right) => (right.t7Median ?? -Infinity) - (left.t7Median ?? -Infinity))
      .findIndex((row) => row.event === eventType) + 1
  : 0;
const sampleRank = currentEventRow
  ? [...validComparisonRows]
      .sort((left, right) => (right.sample ?? -Infinity) - (left.sample ?? -Infinity))
      .findIndex((row) => row.event === eventType) + 1
  : 0;
const hubComparisonNarrative = currentEventRow && validComparisonRows.length > 0
  ? `${eventType} currently ranks #${t7Rank || '--'} of ${validComparisonRows.length} for T+7 up probability, #${medianRank || '--'} for T+7 median return, and #${sampleRank || '--'} for sample depth across the ${asset} event set.`
  : `Cross-event comparison is currently incomplete for ${asset}, so this hub should be read with extra caution until all event rows are populated.`;
const reviewedDateIso = /^\d{4}-\d{2}-\d{2}$/.test(String(reviewedAt))
  ? String(reviewedAt)
  : new Date().toISOString().slice(0, 10);
const schemaExtras = [
  {
    '@type': 'Dataset',
    '@id': `${hubUrl}#dataset`,
    name: `${asset} ${eventType} Event Probability Dataset`,
    description: `Historical CPI/NFP/FOMC probability and median return observations for ${asset}.`,
    url: hubUrl,
    creator: { '@id': `${siteUrl}/#organization` },
    isBasedOn: ['https://fred.stlouisfed.org/', 'https://finance.yahoo.com/'],
    temporalCoverage: `${reviewedDateIso}/${reviewedDateIso}`,
    dateModified: reviewedDateIso,
    variableMeasured: [
      { '@type': 'PropertyValue', name: 'T+1 Up Probability' },
      { '@type': 'PropertyValue', name: 'T+7 Up Probability' },
      { '@type': 'PropertyValue', name: 'T+7 Median Return' },
      { '@type': 'PropertyValue', name: 'Sample Size' },
    ],
  },
];
---

<Layout
  title={hubTitle}
  description={`${asset} × ${eventType} human-guided playbook with thesis, risk watchouts, and execution checklist.`}
  breadcrumbs={breadcrumbs}
  robotsDirective={robotsDirective}
  schemaExtras={schemaExtras}
>
  <section class="hero-panel py-14">
    <div class="max-w-5xl mx-auto px-4">
      <Breadcrumbs items={breadcrumbs} />
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="badge-chip" style="background:rgba(255,255,255,.16);border-color:rgba(255,255,255,.25);color:#e5ecfb;">{asset}</span>
        <span class="badge-chip" style="background:rgba(255,255,255,.16);border-color:rgba(255,255,255,.25);color:#e5ecfb;">{eventType}</span>
        {status === 'draft' ? (
          <span class="badge-chip metric-down">Draft thesis</span>
        ) : (
          <span class="badge-chip metric-up">Approved</span>
        )}
      </div>
      <h1 class="text-4xl font-extrabold text-white">{hubTitle}</h1>
      <p class="text-blue-100 mt-3 text-lg">Human+Template operating view. Reviewed at {reviewedAt}.</p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-10 space-y-4">
    <article class="surface-card p-6">
      <h2 class="text-xl font-extrabold">Thesis</h2>
      <p class="mt-3 text-sm leading-7" style="color:var(--muted);">{brief?.thesis}</p>
    </article>

    <article class="surface-card p-6">
      <h2 class="text-xl font-extrabold">What Changed Recently</h2>
      <p class="mt-3 text-sm leading-7" style="color:var(--muted);">{brief?.what_changed_recently}</p>
    </article>

    <article class="surface-card p-6">
      <h2 class="text-xl font-extrabold">Risk Watchouts</h2>
      <p class="mt-3 text-sm leading-7" style="color:var(--muted);">{brief?.risk_watchouts}</p>
    </article>

    <article class="surface-card p-6">
      <h2 class="text-xl font-extrabold">Cross-event Comparison</h2>
      <p class="mt-2 text-sm" style="color:var(--muted);">
        Compare latest CPI/NFP/FOMC observations for {asset}. This section is unique to Hub pages and is used to avoid
        one-event narrative bias.
      </p>
      <div class="mt-4 grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
          <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Highest T+7 P(up)</p>
          <p class="mt-2 text-lg font-extrabold">{highestT7UpRow?.event || '--'}</p>
          <p class="text-sm" style="color:var(--muted);">
            {highestT7UpRow ? `${highestT7UpRow.t7Up}% on ${highestT7UpRow.eventDate}` : 'Comparison data unavailable.'}
          </p>
        </div>
        <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
          <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Strongest T+7 Median</p>
          <p class="mt-2 text-lg font-extrabold">{highestMedianRow?.event || '--'}</p>
          <p class="text-sm" style="color:var(--muted);">
            {highestMedianRow ? `${highestMedianRow.t7Median}% median return` : 'Comparison data unavailable.'}
          </p>
        </div>
        <div class="rounded-xl border p-4" style="border-color:var(--border);background:var(--surface-alt);">
          <p class="text-xs font-bold uppercase tracking-wide" style="color:var(--muted);">Deepest Sample</p>
          <p class="mt-2 text-lg font-extrabold">{deepestSampleRow?.event || '--'}</p>
          <p class="text-sm" style="color:var(--muted);">
            {deepestSampleRow ? `${deepestSampleRow.sample} matched observations` : 'Comparison data unavailable.'}
          </p>
        </div>
      </div>
      <p class="mt-4 text-sm leading-7" style="color:var(--muted);">
        {hubComparisonNarrative}
        {currentEventRow ? ` The current ${eventType} row prints ${currentEventRow.t1Up}% T+1 up probability and ${currentEventRow.t7Median}% median return, so the operator should read this hub as a relative ranking page rather than a single-event slogan.` : ''}
      </p>
      <div class="mt-4 grid grid-cols-1 xl:grid-cols-2 gap-4">
        <div class="rounded-xl border p-3" style="border-color:var(--border);background:var(--surface);">
          <h3 class="text-sm font-bold mb-2">Probability Overview (T+1/T+7)</h3>
          <div id="hub-prob-chart" style="height:280px;"></div>
        </div>
        <div class="rounded-xl border p-3" style="border-color:var(--border);background:var(--surface);">
          <h3 class="text-sm font-bold mb-2">T+7 Median Return</h3>
          <div id="hub-median-chart" style="height:280px;"></div>
        </div>
      </div>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left" style="color:var(--muted);">
              <th class="py-2 pr-3">Event</th>
              <th class="py-2 pr-3">Latest Date</th>
              <th class="py-2 pr-3">T+1 P(up)</th>
              <th class="py-2 pr-3">T+7 P(up)</th>
              <th class="py-2 pr-3">T+7 Median</th>
              <th class="py-2 pr-3">Sample</th>
              <th class="py-2">Research</th>
            </tr>
          </thead>
          <tbody>
            {hubVisualPayload.map((row) => (
              <tr class="border-t" style="border-color:var(--border);">
                <td class="py-2 pr-3 font-semibold">{row.event}</td>
                <td class="py-2 pr-3">{row.eventDate}</td>
                <td class="py-2 pr-3">{row.t1Up ?? '--'}{row.t1Up !== null ? '%' : ''}</td>
                <td class="py-2 pr-3">{row.t7Up ?? '--'}{row.t7Up !== null ? '%' : ''}</td>
                <td class="py-2 pr-3">{row.t7Median ?? '--'}{row.t7Median !== null ? '%' : ''}</td>
                <td class="py-2 pr-3">{row.sample ?? '--'}</td>
                <td class="py-2">
                  {row.slug ? (
                    <a class="btn-ghost text-xs" href={`/blog/${row.slug}`}>Open</a>
                  ) : (
                    <span class="badge-chip">N/A</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <noscript>
        <div class="mt-3">
          <p class="text-xs" style="color:var(--muted);">
            JavaScript is disabled. Fallback data table:
          </p>
          <table class="w-full text-xs mt-2">
            <thead>
              <tr style="color:var(--muted);">
                <th class="text-left py-1 pr-2">Event</th>
                <th class="text-left py-1 pr-2">Date</th>
                <th class="text-left py-1 pr-2">T+1 P(up)</th>
                <th class="text-left py-1 pr-2">T+7 P(up)</th>
                <th class="text-left py-1 pr-2">T+7 Median</th>
                <th class="text-left py-1">Sample</th>
              </tr>
            </thead>
            <tbody>
              {hubVisualPayload.map((row) => (
                <tr>
                  <td class="py-1 pr-2">{row.event}</td>
                  <td class="py-1 pr-2">{row.eventDate}</td>
                  <td class="py-1 pr-2">{row.t1Up ?? '--'}{row.t1Up !== null ? '%' : ''}</td>
                  <td class="py-1 pr-2">{row.t7Up ?? '--'}{row.t7Up !== null ? '%' : ''}</td>
                  <td class="py-1 pr-2">{row.t7Median ?? '--'}{row.t7Median !== null ? '%' : ''}</td>
                  <td class="py-1">{row.sample ?? '--'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </noscript>
    </article>

    <article class="surface-card p-6">
      <h2 class="text-xl font-extrabold">Execution Checklist</h2>
      <ul class="mt-3 space-y-2 text-sm" style="color:var(--muted);">
        {(brief?.execution_checklist || []).map((item) => (
          <li>• {item}</li>
        ))}
      </ul>
    </article>

    <article class="surface-card p-6">
      <h2 class="text-xl font-extrabold">Related Entrypoints</h2>
      <div class="mt-4 flex flex-wrap gap-2">
        <a class="btn-ghost text-sm" href={`/tags/${asset.toLowerCase()}`}>Open {asset} Asset Hub</a>
        <a class="btn-ghost text-sm" href={`/events/${eventType.toLowerCase()}`}>Open {eventType} Event Hub</a>
        {latestSlug ? (
          <a class="btn-primary text-sm" href={`/blog/${latestSlug}`}>Open Latest Research ({latestEventDate || 'latest'})</a>
        ) : (
          <span class="badge-chip">No linked research yet</span>
        )}
      </div>
    </article>

    <TrustSignals dataLastUpdatedAt={reviewedAt} confidenceLevel={status === 'draft' ? 'low' : 'normal'} />
  </section>
  <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js" defer></script>
  <script is:inline define:vars={{ hubVisualPayload }}>
    (() => {
      const rows = Array.isArray(hubVisualPayload) ? hubVisualPayload : [];
      if (!rows.length) return;

      const render = () => {
        if (!window.echarts) return false;
        const probEl = document.getElementById('hub-prob-chart');
        const medianEl = document.getElementById('hub-median-chart');
        if (!probEl || !medianEl) return true;

        const labels = rows.map((row) => row.event);
        const t1 = rows.map((row) => (typeof row.t1Up === 'number' ? row.t1Up : null));
        const t7 = rows.map((row) => (typeof row.t7Up === 'number' ? row.t7Up : null));
        const median = rows.map((row) => (typeof row.t7Median === 'number' ? row.t7Median : null));

        const probChart = window.echarts.init(probEl);
        probChart.setOption({
          tooltip: { trigger: 'axis' },
          legend: { data: ['T+1 P(up)', 'T+7 P(up)'] },
          xAxis: { type: 'category', data: labels },
          yAxis: { type: 'value', min: 0, max: 100, axisLabel: { formatter: '{value}%' } },
          series: [
            { name: 'T+1 P(up)', type: 'bar', data: t1 },
            { name: 'T+7 P(up)', type: 'bar', data: t7 },
          ],
        });

        const medianChart = window.echarts.init(medianEl);
        medianChart.setOption({
          tooltip: { trigger: 'axis' },
          xAxis: { type: 'category', data: labels },
          yAxis: { type: 'value', axisLabel: { formatter: '{value}%' } },
          series: [{ name: 'T+7 Median', type: 'line', smooth: true, data: median }],
        });
        return true;
      };

      const tryRender = () => {
        if (render()) return;
        let retry = 0;
        const timer = setInterval(() => {
          retry += 1;
          if (render() || retry >= 30) {
            clearInterval(timer);
          }
        }, 150);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', tryRender, { once: true });
      } else {
        tryRender();
      }
    })();
  </script>
</Layout>
