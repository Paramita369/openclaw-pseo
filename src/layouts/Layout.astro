---
import Analytics from '@vercel/analytics/astro';

const { title, description, frontmatter } = Astro.props;

const metaDesc = description || "Quantitative backtesting data for cross-asset volatility post-macro events. Data driven trading insights.";
const siteUrl = "https://quantmacro.vercel.app";
const currentUrl = Astro.url.href;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID || "";

// Dynamic JSON-LD for articles
let schema = null;
if (frontmatter) {
  schema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": metaDesc,
    "author": {
      "@type": "Organization",
      "name": "QuantMacro",
      "url": siteUrl
    },
    "publisher": {
      "@type": "Organization",
      "name": "QuantMacro",
      "logo": {
        "@type": "ImageObject",
        "url": siteUrl + "/favicon.svg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": currentUrl
    },
    "datePublished": frontmatter.pubDate || new Date().toISOString().split('T')[0]
  };
} else {
  // Website schema for homepage
  schema = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "QuantMacro",
    "description": metaDesc,
    "url": siteUrl,
    "publisher": {
      "@type": "Organization",
      "name": "QuantMacro"
    }
  };
}
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="kvvXjMnBnI-4oWLa66hB0XZP3q4t6go7Y37eaSm9g3Y" />
    <title>{title} | QuantMacro Analytics</title>
    <meta name="description" content={metaDesc}>
    <link rel="canonical" href={currentUrl}>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <!-- Google Fonts: Poppins + Open Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;500;600;700&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    {ga4MeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4MeasurementId}`}></script>
        <script is:inline define:vars={{ ga4MeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', ga4MeasurementId);
        </script>
      </>
    )}
</head>

<body class="bg-dark-bg text-dark-text font-body antialiased">
    <header class="bg-dark-surface border-b border-dark-border">
        <nav class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-primary font-heading">QuantMacro</a>
            <div class="space-x-6">
                <a href="/" class="text-gray-300 hover:text-primary transition font-medium">Home</a>
                <a href="/leaderboard" class="text-gray-300 hover:text-primary transition font-medium">α Alpha</a>
                <a href="/blog" class="text-gray-300 hover:text-primary transition font-medium">Analysis</a>
            </div>
        </nav>
    </header>

    <slot />

    <footer class="bg-dark-surface border-t border-dark-border py-8 mt-16">
        <div class="max-w-7xl mx-auto px-4 text-center text-gray-400">
            <p>&copy; 2026 QuantMacro Analytics. Data-driven trading insights.</p>
            <p class="text-sm mt-2">Data updated daily. Trading involves risk.</p>
        </div>
    </footer>

    <Analytics />
    <script is:inline>
      if (!window.__quantmacroAffiliateTracker) {
        window.__quantmacroAffiliateTracker = true;
        document.addEventListener('click', (event) => {
          const target = event.target && event.target.closest && event.target.closest('a[data-affiliate-click=\"1\"]');
          if (!target) return;
          const payload = {
            slug: target.dataset.slug || '',
            asset: target.dataset.asset || '',
            offer_key: target.dataset.offerKey || '',
            cta_position: target.dataset.ctaPosition || '',
            utm_campaign: target.dataset.utmCampaign || '',
          };
          if (window.gtag) {
            window.gtag('event', 'affiliate_click', payload);
          }
        });
      }
    </script>
</body>
</html>
