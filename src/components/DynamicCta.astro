---
import offersConfig from '../data/offers.json';

const { asset = 'BTC', slug = '' } = Astro.props;
const normalizedAsset = String(asset).toUpperCase();

const offerKeys = offersConfig.asset_offer_keys[normalizedAsset] || offersConfig.asset_offer_keys.DEFAULT || [];
const selectedOffers = offerKeys
  .map((key) => ({ key, ...offersConfig.offers[key] }))
  .filter((offer) => Boolean(offer && offer.url));

const utmSource = offersConfig.utm?.source || 'quantmacro';
const utmMedium = offersConfig.utm?.medium || 'affiliate';

const withUtm = (offer) => {
  const url = new URL(offer.url);
  url.searchParams.set('utm_source', utmSource);
  url.searchParams.set('utm_medium', utmMedium);
  url.searchParams.set('utm_campaign', offer.utm_campaign || `affiliate_${offer.key}`);
  if (slug) {
    url.searchParams.set('utm_content', slug);
  }
  return url.toString();
};

const colorClass = (name, primary = true) => {
  const map = {
    yellow: primary ? 'bg-yellow-500 hover:bg-yellow-600 text-slate-900' : 'bg-yellow-50 text-yellow-800 border-yellow-200',
    emerald: primary ? 'bg-emerald-600 hover:bg-emerald-700 text-white' : 'bg-emerald-50 text-emerald-800 border-emerald-200',
    purple: primary ? 'bg-purple-600 hover:bg-purple-700 text-white' : 'bg-purple-50 text-purple-800 border-purple-200',
    blue: primary ? 'bg-blue-600 hover:bg-blue-700 text-white' : 'bg-blue-50 text-blue-800 border-blue-200',
  };
  return map[name] || map.blue;
};
---

{selectedOffers.length > 0 && (
  <div class="mt-10 mb-8 p-6 border-l-4 rounded-r-xl shadow-sm bg-gradient-to-r from-blue-50 to-indigo-50 border-blue-600">
    <h3 class="text-lg font-black text-slate-900 mb-2">Quantitative Action Plan</h3>

    {selectedOffers.length === 1 ? (
      <div>
        <p class="text-slate-700 mb-4 font-medium">{selectedOffers[0].message_template.replace('{asset}', normalizedAsset)}</p>
        <a
          href={withUtm(selectedOffers[0])}
          target="_blank"
          rel="noopener noreferrer"
          data-affiliate-click="1"
          data-slug={slug}
          data-asset={normalizedAsset}
          data-offer-key={selectedOffers[0].key}
          data-cta-position="article_inline"
          data-utm-campaign={selectedOffers[0].utm_campaign || `affiliate_${selectedOffers[0].key}`}
          class={`inline-flex items-center gap-2 font-bold py-3 px-6 rounded-lg transition-all shadow-sm ${colorClass(selectedOffers[0].button_style)}`}
        >
          Open {selectedOffers[0].name} Account →
        </a>
      </div>
    ) : (
      <div class="space-y-3">
        <p class="text-slate-700 mb-2 font-medium">Choose your preferred trading platform:</p>
        <div class="flex flex-col sm:flex-row gap-3">
          {selectedOffers.map((offer, idx) => (
            <a
              href={withUtm(offer)}
              target="_blank"
              rel="noopener noreferrer"
              data-affiliate-click="1"
              data-slug={slug}
              data-asset={normalizedAsset}
              data-offer-key={offer.key}
              data-cta-position="article_inline"
              data-utm-campaign={offer.utm_campaign || `affiliate_${offer.key}`}
              class={`inline-flex items-center justify-center gap-2 font-bold py-3 px-4 rounded-lg transition-all shadow-sm ${colorClass(offer.button_style, idx === 0)}`}
            >
              Open {offer.name} →
            </a>
          ))}
        </div>
      </div>
    )}

    <p class="text-xs text-slate-500 mt-4">*Trading involves risk. This is for educational purposes only.</p>
  </div>
)}
