---
const { data, asset, title } = Astro.props;
const chartId = `tv-chart-${asset}-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="rounded-xl border overflow-hidden mb-8" style="border-color:var(--border);background:var(--surface);">
  <div class="px-5 py-3 border-b flex justify-between items-center" style="border-color:var(--border);background:var(--surface-alt);">
    <h4 class="text-sm font-bold">{title || `${asset} Price Action (T-3 to T+7)`}</h4>
    <span class="text-xs" style="color:var(--muted);">Candlestick</span>
  </div>
  <div id={chartId} class="w-full h-[350px]" data-chart={JSON.stringify(data)}></div>
</div>

<script define:vars={{ chartId }}>
  import { createChart } from 'lightweight-charts';

  const getThemePalette = () => {
    const theme = document.documentElement.getAttribute('data-theme') || 'light';
    if (theme === 'dark') {
      return {
        bg: '#111d36',
        text: '#dce7ff',
        grid: '#243755',
        border: '#2f4163',
      };
    }
    return {
      bg: '#ffffff',
      text: '#1a2947',
      grid: '#e5ebf4',
      border: '#d2dbe8',
    };
  };

  const mountChart = () => {
    const el = document.getElementById(chartId);
    if (!el) return null;

    const rawData = el.getAttribute('data-chart');
    if (!rawData) return null;

    const chartData = JSON.parse(rawData);
    if (!chartData || chartData.length === 0) return null;

    const palette = getThemePalette();
    const chart = createChart(el, {
      layout: {
        background: { color: palette.bg },
        textColor: palette.text,
      },
      grid: {
        vertLines: { color: palette.grid },
        horzLines: { color: palette.grid },
      },
      timeScale: {
        borderColor: palette.border,
        timeVisible: true,
      },
      rightPriceScale: {
        borderColor: palette.border,
      },
      width: el.clientWidth,
      height: 350,
    });

    const series = chart.addCandlestickSeries({
      upColor: '#22a775',
      downColor: '#d15757',
      borderVisible: false,
      wickUpColor: '#22a775',
      wickDownColor: '#d15757',
    });

    series.setData(chartData);
    chart.timeScale().fitContent();

    const onResize = () => chart.applyOptions({ width: el.clientWidth });
    window.addEventListener('resize', onResize);

    const onThemeChange = () => {
      const next = getThemePalette();
      chart.applyOptions({
        layout: { background: { color: next.bg }, textColor: next.text },
        grid: { vertLines: { color: next.grid }, horzLines: { color: next.grid } },
        timeScale: { borderColor: next.border },
        rightPriceScale: { borderColor: next.border },
      });
    };
    window.addEventListener('theme-change', onThemeChange);

    return () => {
      window.removeEventListener('resize', onResize);
      window.removeEventListener('theme-change', onThemeChange);
      chart.remove();
    };
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountChart, { once: true });
  } else {
    mountChart();
  }
</script>
