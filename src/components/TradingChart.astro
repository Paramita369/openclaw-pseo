---
const {
  data,
  asset,
  title,
  eventDate = '',
  windowLabel = 'T-3 to T+7',
  historicalNotice = 'Historical Event Window (T-3 to T+7), not live market data',
} = Astro.props;
const chartId = `tv-chart-${asset}-${Math.random().toString(36).slice(2, 8)}`;
const skeletonId = `${chartId}-skeleton`;
const fallbackId = `${chartId}-fallback`;
const markerHintId = `${chartId}-marker-hint`;
---

<div class="rounded-xl border overflow-hidden mb-8" style="border-color:var(--border);background:var(--surface);">
  <div class="px-5 py-3 border-b flex justify-between items-center" style="border-color:var(--border);background:var(--surface-alt);">
    <h4 class="text-sm font-bold">{title || `${asset} Price Action (${windowLabel})`}</h4>
    <span class="text-xs" style="color:var(--muted);">Candlestick · Historical</span>
  </div>
  <div class="px-5 py-2 border-b text-xs" style="border-color:var(--border);background:var(--surface);color:var(--muted);">
    {historicalNotice}
    <span id={markerHintId} class="ml-2"></span>
  </div>
  <div class="relative w-full h-[350px]">
    <div id={skeletonId} class="chart-skeleton absolute inset-0 animate-pulse"></div>
    <div id={fallbackId} class="hidden absolute inset-0 p-5 text-sm" style="color:var(--muted);">
      Chart data is temporarily unavailable for this event window.
    </div>
    <div
      id={chartId}
      class="w-full h-[350px] opacity-0 transition-opacity duration-200"
      data-chart={JSON.stringify(data)}
      data-event-date={eventDate}
    ></div>
  </div>
</div>

<script define:vars={{ chartId, skeletonId, fallbackId, markerHintId }}>
  import { createChart, createSeriesMarkers } from 'lightweight-charts';

  const getThemePalette = () => {
    const theme = document.documentElement.getAttribute('data-theme') || 'light';
    if (theme === 'dark') {
      return {
        bg: '#111d36',
        text: '#dce7ff',
        grid: '#243755',
        border: '#2f4163',
      };
    }
    return {
      bg: '#ffffff',
      text: '#1a2947',
      grid: '#e5ebf4',
      border: '#d2dbe8',
    };
  };

  const mountChart = () => {
    const el = document.getElementById(chartId);
    const skeleton = document.getElementById(skeletonId);
    const fallback = document.getElementById(fallbackId);
    const markerHint = document.getElementById(markerHintId);
    const showFallback = () => {
      if (skeleton) skeleton.classList.add('hidden');
      if (fallback) fallback.classList.remove('hidden');
      if (el) el.classList.add('hidden');
    };
    const revealChart = () => {
      if (skeleton) skeleton.classList.add('hidden');
      if (fallback) fallback.classList.add('hidden');
      if (el) {
        el.classList.remove('hidden');
        el.classList.remove('opacity-0');
      }
    };

    if (!el) return null;

    const rawData = el.getAttribute('data-chart');
    if (!rawData) {
      showFallback();
      return null;
    }

    const chartData = JSON.parse(rawData);
    if (!chartData || chartData.length === 0) {
      showFallback();
      return null;
    }

    const palette = getThemePalette();
    try {
      const chart = createChart(el, {
        layout: {
          background: { color: palette.bg },
          textColor: palette.text,
        },
        grid: {
          vertLines: { color: palette.grid },
          horzLines: { color: palette.grid },
        },
        timeScale: {
          borderColor: palette.border,
          timeVisible: true,
        },
        rightPriceScale: {
          borderColor: palette.border,
        },
        width: el.clientWidth,
        height: 350,
      });

      const series = chart.addCandlestickSeries({
        upColor: '#22a775',
        downColor: '#d15757',
        borderVisible: false,
        wickUpColor: '#22a775',
        wickDownColor: '#d15757',
      });

      series.setData(chartData);
      const eventDate = String(el.getAttribute('data-event-date') || '').slice(0, 10);
      const hasMarker = Boolean(eventDate && chartData.some((point) => String(point.time) === eventDate));
      if (hasMarker) {
        createSeriesMarkers(series, [
          {
            time: eventDate,
            position: 'belowBar',
            color: '#f59e0b',
            shape: 'circle',
            text: 'T0 Event Trigger',
          },
        ]);
        if (markerHint) markerHint.textContent = `· T0 Event Trigger: ${eventDate}`;
      } else if (markerHint) {
        markerHint.textContent = '· T0 marker unavailable for this window';
      }
      chart.timeScale().fitContent();
      revealChart();

      const onResize = () => chart.applyOptions({ width: el.clientWidth });
      window.addEventListener('resize', onResize);

      const onThemeChange = () => {
        const next = getThemePalette();
        chart.applyOptions({
          layout: { background: { color: next.bg }, textColor: next.text },
          grid: { vertLines: { color: next.grid }, horzLines: { color: next.grid } },
          timeScale: { borderColor: next.border },
          rightPriceScale: { borderColor: next.border },
        });
      };
      window.addEventListener('theme-change', onThemeChange);

      return () => {
        window.removeEventListener('resize', onResize);
        window.removeEventListener('theme-change', onThemeChange);
        chart.remove();
      };
    } catch {
      showFallback();
      return null;
    }
  };

  const hydrateChart = () => {
    try {
      mountChart();
    } catch {
      const skeleton = document.getElementById(skeletonId);
      const fallback = document.getElementById(fallbackId);
      if (skeleton) skeleton.classList.add('hidden');
      if (fallback) fallback.classList.remove('hidden');
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', hydrateChart, { once: true });
  } else {
    hydrateChart();
  }
</script>
